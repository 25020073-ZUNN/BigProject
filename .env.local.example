# Database Configuration (Optional - Docker overrides these)
DB_URL=jdbc:mysql://localhost:3307/auction_db?useSSL=false
DB_USER=root
DB_PASSWORD=123456

# Cloudinary Configuration (Optional - For cloud image storage)
# You can use the URL format:
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# OR individual components:
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=auction-items

# Server Port (Optional)
SERVER_PORT=5050
