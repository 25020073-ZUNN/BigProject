<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.HomeController"
            prefWidth="1380"
            prefHeight="900"
            stylesheets="@style.css"
            styleClass="root">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="18" styleClass="topbar">
            <padding>
                <Insets top="14" right="28" bottom="14" left="28"/>
            </padding>

            <VBox spacing="0">
                <Label text="AUREX" styleClass="logo-main"/>
                <Label text="AUCTION PLATFORM" styleClass="logo-sub"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Trang chủ" onAction="#goToHome" styleClass="nav-btn"/>
            <Button text="Tài sản đấu giá" onAction="#goToAuctionList" styleClass="nav-btn"/>
            <Button text="Phiên đấu giá" onAction="#goToSessions" styleClass="nav-btn"/>
            <Button text="Tin tức" onAction="#goToNews" styleClass="nav-btn"/>
            <Button text="Liên hệ" onAction="#goToContact" styleClass="nav-btn"/>
            <Label fx:id="dbStatusLabel" text="DB: checking..." styleClass="partner-text"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="22" styleClass="page-section">
            <padding>
                <Insets top="30" right="42" bottom="30" left="42"/>
            </padding>

            <VBox spacing="10">
                <Label text="Tạo tài khoản mới" styleClass="section-title-dark"/>
                <Label text="Đăng ký tài khoản để tham gia đấu giá, nhận thông báo tài sản mới và quản lý lịch sử tham gia."
                       wrapText="true" styleClass="section-subtitle"/>
            </VBox>

            <HBox spacing="24">
                <VBox prefWidth="860" spacing="20" styleClass="register-panel">
                    <padding>
                        <Insets top="26" right="26" bottom="26" left="26"/>
                    </padding>

                    <Label text="Thông tin đăng ký" styleClass="login-panel-title"/>

                    <GridPane hgap="18" vgap="16">
                        <Label text="Họ và tên" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="field-label"/>
                        <TextField fx:id="fullNameField" promptText="Nhập họ và tên" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="mail-field"/>

                        <Label text="Tên đăng nhập" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="field-label"/>
                        <TextField fx:id="regUsernameField" promptText="Nhập tên đăng nhập" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="mail-field"/>

                        <Label text="Số điện thoại" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="field-label"/>
                        <TextField fx:id="phoneField" promptText="Nhập số điện thoại" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="mail-field"/>

                        <Label text="Email" GridPane.columnIndex="1" GridPane.rowIndex="2" styleClass="field-label"/>
                        <TextField fx:id="emailField" promptText="example@gmail.com" GridPane.columnIndex="1" GridPane.rowIndex="3" styleClass="mail-field"/>

                        <Label text="CMND/CCCD" GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="field-label"/>
                        <TextField fx:id="idCardField" promptText="Nhập số giấy tờ" GridPane.columnIndex="0" GridPane.rowIndex="5" styleClass="mail-field"/>

                        <Label text="Địa chỉ" GridPane.columnIndex="1" GridPane.rowIndex="4" styleClass="field-label"/>
                        <TextField fx:id="addressField" promptText="Nhập địa chỉ liên hệ" GridPane.columnIndex="1" GridPane.rowIndex="5" styleClass="mail-field"/>

                        <Label text="Mật khẩu" GridPane.columnIndex="0" GridPane.rowIndex="6" styleClass="field-label"/>
                        <PasswordField fx:id="regPasswordField" promptText="Nhập mật khẩu" GridPane.columnIndex="0" GridPane.rowIndex="7" styleClass="mail-field"/>

                        <Label text="Xác nhận mật khẩu" GridPane.columnIndex="1" GridPane.rowIndex="6" styleClass="field-label"/>
                        <PasswordField fx:id="confirmPasswordField" promptText="Nhập lại mật khẩu" GridPane.columnIndex="1" GridPane.rowIndex="7" styleClass="mail-field"/>
                    </GridPane>

                    <VBox spacing="10">
                        <CheckBox text="Tôi đồng ý với điều khoản sử dụng và chính sách bảo mật" styleClass="check-auth"/>
                        <CheckBox text="Tôi muốn nhận thông báo về phiên đấu giá và tài sản mới" styleClass="check-auth"/>
                    </VBox>

                    <HBox spacing="12">
                        <Button text="Tạo tài khoản" onAction="#handleRegister" styleClass="primary-btn"/>
                        <Button text="Làm mới biểu mẫu" styleClass="secondary-btn"/>
                    </HBox>
                </VBox>

                <VBox prefWidth="410" spacing="16">
                    <VBox spacing="14" styleClass="side-info-card">
                        <padding>
                            <Insets top="22" right="22" bottom="22" left="22"/>
                        </padding>

                        <Label text="Quy trình kích hoạt tài khoản" styleClass="partner-title"/>
                        <Label text="1. Điền thông tin cá nhân&#10;2. Xác thực email / số điện thoại&#10;3. Hoàn thiện hồ sơ&#10;4. Bắt đầu tham gia đấu giá"
                               wrapText="true" styleClass="partner-text"/>
                    </VBox>

                    <VBox spacing="14" styleClass="side-info-card">
                        <padding>
                            <Insets top="22" right="22" bottom="22" left="22"/>
                        </padding>

                        <Label text="Lợi ích khi đăng ký" styleClass="partner-title"/>
                        <Label text="• Theo dõi tài sản yêu thích&#10;• Nhận thông báo nhắc lịch&#10;• Quản lý lịch sử tham gia&#10;• Truy cập hồ sơ và biên bản"
                               wrapText="true" styleClass="partner-text"/>
                    </VBox>

                    <VBox spacing="14" styleClass="side-info-card-dark">
                        <padding>
                            <Insets top="22" right="22" bottom="22" left="22"/>
                        </padding>

                        <Label text="Đã có tài khoản?" styleClass="section-title"/>
                        <Label text="Đăng nhập để tiếp tục theo dõi các phiên đang mở và trạng thái hồ sơ."
                               wrapText="true" styleClass="footer-text"/>
                        <Hyperlink text="Chuyển sang trang đăng nhập" onAction="#goToLogin" styleClass="auth-link-light"/>
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
