<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.controller.AssetDetailController"
            prefWidth="1380" prefHeight="920" stylesheets="@style.css" styleClass="root">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="topbar">
                <padding><Insets top="12" right="36" bottom="12" left="36"/></padding>
                <VBox spacing="0">
                    <Label text="AUREX" styleClass="logo-main"/>
                    <Label text="AUCTION PLATFORM" styleClass="logo-sub"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Trang chủ" onAction="#goToHome" styleClass="nav-btn"/>
                <Button text="Tài sản đấu giá" onAction="#goToAuctionList" styleClass="nav-btn-active"/>
                <Button text="Phiên đấu giá" onAction="#goToSessions" styleClass="nav-btn"/>
                <Button text="Tin tức" onAction="#goToNews" styleClass="nav-btn"/>
                <Button text="Liên hệ" onAction="#goToContact" styleClass="nav-btn"/>
                <Button fx:id="loginButton" text="Đăng nhập" onAction="#goToLogin" styleClass="login-btn"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="main-scroll">
            <content>
                <VBox spacing="0">

                    <!-- ═══ Breadcrumb ═══ -->
                    <HBox spacing="6" alignment="CENTER_LEFT" style="-fx-background-color: #fafafa; -fx-border-color: transparent transparent #e0e0e0 transparent; -fx-border-width: 0 0 1 0;">
                        <padding><Insets top="14" right="48" bottom="14" left="48"/></padding>
                        <Label text="🏠" style="-fx-font-size: 13px;"/>
                        <Button text="Trang chủ" onAction="#goToHome" styleClass="auth-link" style="-fx-font-size: 13px;"/>
                        <Label text="›" styleClass="muted-text"/>
                        <Button text="Tài sản đấu giá" onAction="#goToAuctionList" styleClass="auth-link" style="-fx-font-size: 13px;"/>
                        <Label text="›" styleClass="muted-text"/>
                        <Label fx:id="breadcrumbName" text="Tên tài sản" style="-fx-text-fill: #0078d4; -fx-font-size: 13px; -fx-font-weight: 600;"/>
                    </HBox>

                    <!-- ═══ Header ═══ -->
                    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #ffffff;">
                        <padding><Insets top="20" right="48" bottom="20" left="48"/></padding>
                        <VBox spacing="8">
                            <Label text="Chi tiết tài sản đấu giá" styleClass="hero-title-small"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Trạng thái:" styleClass="field-label"/>
                                <Label fx:id="lblStatusBadge" text="⏳ Chờ bắt đầu" styleClass="badge-new"/>
                            </HBox>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="← Quay lại danh sách" onAction="#goToAuctionList" styleClass="secondary-btn"/>
                    </HBox>

                    <Separator/>

                    <!-- ═══ Main Content: 2 columns ═══ -->
                    <HBox spacing="28" styleClass="page-section">
                        <padding><Insets top="32" right="48" bottom="48" left="48"/></padding>

                        <!-- ═══ CỘT TRÁI: Thông tin tài sản ═══ -->
                        <VBox spacing="24" HBox.hgrow="ALWAYS">

                            <!-- Hình ảnh tài sản -->
                            <VBox alignment="CENTER" prefHeight="360" styleClass="content-card"
                                  style="-fx-background-color: linear-gradient(to bottom right, #f0f7ff, #e8e8e8); -fx-background-radius: 16;">
                                <Label text="🖼" style="-fx-font-size: 80;"/>
                                <Label text="Hình ảnh tài sản" styleClass="muted-text"/>
                            </VBox>

                            <!-- Mô tả tài sản -->
                            <VBox spacing="14" styleClass="content-card">
                                <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>
                                <Label text="📋  Mô tả tài sản" styleClass="partner-title"/>
                                <Separator/>
                                <Label fx:id="lblDescription" text="Đang tải mô tả..." styleClass="partner-text" wrapText="true"/>
                            </VBox>

                            <!-- Thông tin chi tiết -->
                            <VBox spacing="14" styleClass="content-card">
                                <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>
                                <Label text="📊  Thông tin chi tiết" styleClass="partner-title"/>
                                <Separator/>

                                <HBox spacing="40">
                                    <VBox spacing="10" HBox.hgrow="ALWAYS">
                                        <HBox spacing="8" alignment="CENTER_LEFT">
                                            <Label text="Mã tài sản:" styleClass="field-label" prefWidth="130"/>
                                            <Label fx:id="lblItemId" text="---" styleClass="partner-text-strong"/>
                                        </HBox>
                                        <HBox spacing="8" alignment="CENTER_LEFT">
                                            <Label text="Danh mục:" styleClass="field-label" prefWidth="130"/>
                                            <Label fx:id="lblCategory" text="---" styleClass="partner-text-strong"/>
                                        </HBox>
                                        <HBox spacing="8" alignment="CENTER_LEFT">
                                            <Label text="Người bán:" styleClass="field-label" prefWidth="130"/>
                                            <Label fx:id="lblSeller" text="---" styleClass="partner-text-strong"/>
                                        </HBox>
                                    </VBox>
                                    <VBox spacing="10" HBox.hgrow="ALWAYS">
                                        <HBox spacing="8" alignment="CENTER_LEFT">
                                            <Label text="Mã phiên:" styleClass="field-label" prefWidth="130"/>
                                            <Label fx:id="lblAuctionId" text="---" styleClass="partner-text-strong"/>
                                        </HBox>
                                        <HBox spacing="8" alignment="CENTER_LEFT">
                                            <Label text="Bước giá:" styleClass="field-label" prefWidth="130"/>
                                            <Label fx:id="lblBidStep" text="---" styleClass="partner-text-strong"/>
                                        </HBox>
                                        <HBox spacing="8" alignment="CENTER_LEFT">
                                            <Label text="Số lượt đặt giá:" styleClass="field-label" prefWidth="130"/>
                                            <Label fx:id="lblBidCount" text="0" styleClass="partner-text-strong"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                            </VBox>
                        </VBox>

                        <!-- ═══ CỘT PHẢI: Countdown + Hành động ═══ -->
                        <VBox prefWidth="380" spacing="20">

                            <!-- Countdown Card -->
                            <VBox spacing="16" styleClass="content-card">
                                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

                                <Label fx:id="lblCountdownTitle" text="⏰  Thời gian bắt đầu đấu giá" styleClass="partner-title"/>

                                <HBox spacing="12" alignment="CENTER">
                                    <VBox alignment="CENTER" prefWidth="72" prefHeight="72"
                                          style="-fx-background-color: #f0f7ff; -fx-background-radius: 12; -fx-border-color: #deecf9; -fx-border-radius: 12;">
                                        <Label fx:id="lblDays" text="0" style="-fx-font-size: 28px; -fx-font-weight: 900; -fx-text-fill: #0078d4;"/>
                                        <Label text="Ngày" styleClass="muted-text" style="-fx-font-size: 11px;"/>
                                    </VBox>
                                    <VBox alignment="CENTER" prefWidth="72" prefHeight="72"
                                          style="-fx-background-color: #f0f7ff; -fx-background-radius: 12; -fx-border-color: #deecf9; -fx-border-radius: 12;">
                                        <Label fx:id="lblHours" text="0" style="-fx-font-size: 28px; -fx-font-weight: 900; -fx-text-fill: #0078d4;"/>
                                        <Label text="Giờ" styleClass="muted-text" style="-fx-font-size: 11px;"/>
                                    </VBox>
                                    <VBox alignment="CENTER" prefWidth="72" prefHeight="72"
                                          style="-fx-background-color: #f0f7ff; -fx-background-radius: 12; -fx-border-color: #deecf9; -fx-border-radius: 12;">
                                        <Label fx:id="lblMinutes" text="0" style="-fx-font-size: 28px; -fx-font-weight: 900; -fx-text-fill: #0078d4;"/>
                                        <Label text="Phút" styleClass="muted-text" style="-fx-font-size: 11px;"/>
                                    </VBox>
                                    <VBox alignment="CENTER" prefWidth="72" prefHeight="72"
                                          style="-fx-background-color: #f0f7ff; -fx-background-radius: 12; -fx-border-color: #deecf9; -fx-border-radius: 12;">
                                        <Label fx:id="lblSeconds" text="0" style="-fx-font-size: 28px; -fx-font-weight: 900; -fx-text-fill: #0078d4;"/>
                                        <Label text="Giây" styleClass="muted-text" style="-fx-font-size: 11px;"/>
                                    </VBox>
                                </HBox>

                                <Separator/>

                                <VBox spacing="8">
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label text="Bắt đầu:" styleClass="field-label" prefWidth="100"/>
                                        <Label fx:id="lblStartTime" text="---" styleClass="partner-text-strong"/>
                                    </HBox>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label text="Kết thúc:" styleClass="field-label" prefWidth="100"/>
                                        <Label fx:id="lblEndTime" text="---" styleClass="partner-text-strong"/>
                                    </HBox>
                                </VBox>
                            </VBox>

                            <!-- Price Card -->
                            <VBox spacing="14" styleClass="content-card">
                                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                                <Label text="💰  Thông tin giá" styleClass="partner-title"/>
                                <Separator/>
                                <VBox spacing="10">
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label text="Giá khởi điểm:" styleClass="field-label" prefWidth="120"/>
                                        <Label fx:id="lblStartPrice" text="0 VNĐ"
                                               style="-fx-text-fill: #333; -fx-font-weight: 800; -fx-font-size: 15px;"/>
                                    </HBox>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label text="Giá hiện tại:" styleClass="field-label" prefWidth="120"/>
                                        <Label fx:id="lblCurrentPrice" text="0 VNĐ"
                                               style="-fx-text-fill: #0078d4; -fx-font-weight: 900; -fx-font-size: 18px;"/>
                                    </HBox>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label text="Người dẫn đầu:" styleClass="field-label" prefWidth="120"/>
                                        <Label fx:id="lblLeader" text="Chưa có"
                                               style="-fx-text-fill: #107c10; -fx-font-weight: 700;"/>
                                    </HBox>
                                </VBox>
                            </VBox>

                            <!-- Action Buttons -->
                            <VBox spacing="12">
                                <Button fx:id="btnJoinAuction" text="🏛  Tham gia đấu giá" maxWidth="1.7976931348623157E308"
                                        onAction="#handleJoinAuction" styleClass="primary-btn"
                                        style="-fx-font-size: 15px; -fx-padding: 16 24;"/>
                                <Button text="📋  Xem tổng kết phiên" maxWidth="1.7976931348623157E308"
                                        fx:id="btnViewSummary" onAction="#handleViewSummary" styleClass="secondary-btn"/>
                            </VBox>

                            <!-- Share Card -->
                            <VBox spacing="10" styleClass="content-card">
                                <padding><Insets top="18" right="22" bottom="18" left="22"/></padding>
                                <Label text="📤  Chia sẻ thông tin" styleClass="partner-title"/>
                                <HBox spacing="12">
                                    <Button text="📘 Facebook" styleClass="chip-btn"/>
                                    <Button text="💬 Messenger" styleClass="chip-btn"/>
                                    <Button text="📋 Sao chép" styleClass="chip-btn"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
