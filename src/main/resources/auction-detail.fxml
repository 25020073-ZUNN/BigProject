<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.controller.AuctionCatalogController"
            prefWidth="1380"
            prefHeight="920"
            stylesheets="@style.css"
            styleClass="root">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="topbar">
                <padding>
                    <Insets top="12" right="36" bottom="12" left="36"/>
                </padding>

                <VBox spacing="0">
                    <Label text="AUREX" styleClass="logo-main"/>
                    <Label text="AUCTION PLATFORM" styleClass="logo-sub"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Trang chủ" onAction="#goToHome" styleClass="nav-btn"/>
                <Button text="Tài sản đấu giá" onAction="#goToAuctionList" styleClass="nav-btn-active"/>
                <Button text="Phiên đấu giá" onAction="#goToSessions" styleClass="nav-btn"/>
                <Button text="Tin tức" onAction="#goToNews" styleClass="nav-btn"/>
                <Button text="Liên hệ" onAction="#goToContact" styleClass="nav-btn"/>
                <Button fx:id="loginButton" text="Đăng nhập" onAction="#goToLogin" styleClass="login-btn"/>
            </HBox>

            <!-- Hero: Tiêu đề trang danh sách tài sản -->
            <VBox spacing="12" styleClass="page-hero-small">
                <padding>
                    <Insets top="28" right="48" bottom="28" left="48"/>
                </padding>
                <Label text="Danh sách tài sản đấu giá thật" styleClass="hero-title-small"/>
                <Label text="Tìm kiếm và lọc trực tiếp từ dữ liệu tài sản, phiên và mức giá thật trong cơ sở dữ liệu."
                       styleClass="hero-desc" wrapText="true"/>
            </VBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="main-scroll">
            <content>
                <VBox spacing="24" styleClass="page-section">
                    <padding>
                        <Insets top="28" right="48" bottom="36" left="48"/>
                    </padding>

                    <VBox spacing="16" styleClass="filter-box">
                        <padding>
                            <Insets top="18" right="18" bottom="18" left="18"/>
                        </padding>

                        <HBox spacing="14" alignment="CENTER_LEFT">
                            <TextField fx:id="searchField" promptText="Tìm theo tên tài sản, mã tài sản, mã phiên, người bán..." HBox.hgrow="ALWAYS" styleClass="mail-field"/>
                            <ComboBox fx:id="categoryFilter" promptText="Danh mục" prefWidth="180" styleClass="mail-field"/>
                            <ComboBox fx:id="statusFilter" promptText="Trạng thái" prefWidth="180" styleClass="mail-field"/>
                            <Button text="Tìm kiếm" onAction="#handleSearch" styleClass="primary-btn"/>
                            <Button text="Thêm tài sản đấu giá" onAction="#goToCreateAuction" styleClass="secondary-btn"/>
                        </HBox>

                        <HBox alignment="CENTER_LEFT">
                            <Label fx:id="resultCountLabel" text="0 tài sản phù hợp" styleClass="section-subtitle-bold"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="Dữ liệu đang đọc trực tiếp từ DB" styleClass="auction-notice"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="auctionListContainer" spacing="16"/>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
