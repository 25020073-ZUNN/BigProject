<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.controller.AuctionDetailController"
            prefWidth="1380"
            prefHeight="920"
            stylesheets="@../style.css"
            styleClass="root">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="18" styleClass="topbar">
            <padding>
                <Insets top="12" right="36" bottom="12" left="36"/>
            </padding>
                            <HBox alignment="CENTER_LEFT" spacing="10">
                    <ImageView fitHeight="42" preserveRatio="true">
                        <image>
                            <Image url="@../images/d33812d6433b838f8d0f44c71287e89a.jpg"/>
                        </image>
                    </ImageView>
                    <VBox spacing="0">
                        <Label text="UET" styleClass="logo-main" style="-fx-font-size: 20px;"/>
                        <Label text="AUCTION PLATFORM" styleClass="logo-sub" style="-fx-font-size: 9px;"/>
                    </VBox>
                </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Trang chủ" onAction="#goToHome" styleClass="nav-btn"/>
            <Button text="Tài sản đấu giá" onAction="#goToAuctionList" styleClass="nav-btn-active"/>
            <Button text="Tin tức" onAction="#goToNews" styleClass="nav-btn"/>
            <Button text="Liên hệ" onAction="#goToContact" styleClass="nav-btn"/>
            <Button fx:id="loginButton" text="Đăng nhập" onAction="#goToLogin" styleClass="login-btn"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="main-scroll">
            <content>
                <VBox spacing="22" styleClass="page-section">
                    <padding>
                        <Insets top="28" right="48" bottom="36" left="48"/>
                    </padding>

                    <!-- Tiêu đề + Trạng thái đồng bộ -->
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="Màn hình đấu giá realtime" styleClass="section-title-dark"/>
                        <Label fx:id="lblNotification" text="Đang đồng bộ dữ liệu phiên đấu giá." styleClass="auction-notice"/>
                    </HBox>

                    <HBox spacing="22">
                        <!-- Panel trái: Thông tin phiên đấu giá + Trưng bày sản phẩm -->
                        <VBox spacing="18" prefWidth="440" minWidth="440" styleClass="detail-side-card">
                            <padding>
                                <Insets top="24" right="22" bottom="24" left="22"/>
                            </padding>

                            <!-- Ảnh sản phẩm với Badge trạng thái nổi -->
                            <StackPane styleClass="detail-image-container" prefHeight="250" maxHeight="250">
                                <ImageView fx:id="imgProduct" fitWidth="390" fitHeight="250" preserveRatio="true" smooth="true"/>
                                <Label fx:id="lblStatus" text="RUNNING" styleClass="badge-live" StackPane.alignment="TOP_LEFT">
                                    <StackPane.margin>
                                        <Insets top="12" left="12"/>
                                    </StackPane.margin>
                                </Label>
                            </StackPane>

                            <!-- Tiêu đề sản phẩm & Người bán -->
                            <VBox spacing="6">
                                <Label fx:id="lblName" text="Honda Vision 2023" styleClass="hero-title-small" wrapText="true"/>
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <Label text="Người bán:" styleClass="mini-info-text"/>
                                    <Label fx:id="lblSeller" text="seller_001" styleClass="partner-text-strong" wrapText="true"/>
                                </HBox>
                            </VBox>

                            <Separator/>

                            <!-- Hộp Giá hiện tại & Đồng hồ Đếm ngược -->
                            <HBox spacing="14">
                                <VBox HBox.hgrow="ALWAYS" styleClass="detail-price-box" spacing="4">
                                    <Label text="Giá hiện tại" styleClass="field-label" style="-fx-text-fill: #0078d4;"/>
                                    <Label fx:id="lblPrice" text="25,500,000 VND" styleClass="detail-price" style="-fx-font-size: 18px;"/>
                                </VBox>
                                <VBox HBox.hgrow="ALWAYS" styleClass="detail-countdown-box" spacing="4">
                                    <Label text="Thời gian còn lại" styleClass="field-label" style="-fx-text-fill: #e11d48;"/>
                                    <Label fx:id="lblTime" text="00:00:00" styleClass="detail-countdown-value"/>
                                </VBox>
                            </HBox>

                            <!-- Grid thông tin phụ (Dẫn đầu & Bước giá) -->
                            <HBox spacing="14">
                                <VBox HBox.hgrow="ALWAYS" styleClass="detail-stats-card" spacing="4">
                                    <Label text="Người dẫn đầu" styleClass="detail-stats-title"/>
                                    <Label fx:id="lblLeader" text="Chưa có" styleClass="detail-stats-value" wrapText="true"/>
                                </VBox>
                                <VBox HBox.hgrow="ALWAYS" styleClass="detail-stats-card" spacing="4">
                                    <Label text="Bước giá tối thiểu" styleClass="detail-stats-title"/>
                                    <Label fx:id="lblMinimumBid" text="500,000 VND" styleClass="detail-stats-value"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Panel phải: Bàn điều khiển tác vụ + Biểu đồ + Lịch sử -->
                        <VBox spacing="18" HBox.hgrow="ALWAYS">
                            <!-- Hàng 1: Bàn điều khiển & Lịch sử -->
                            <HBox spacing="22" VBox.vgrow="ALWAYS">
                                <!-- Bàn điều khiển tác vụ đặt giá -->
                                <VBox spacing="16" styleClass="bidding-console-card" HBox.hgrow="ALWAYS">
                                    <padding>
                                        <Insets top="20" right="20" bottom="20" left="20"/>
                                    </padding>
                                    <Label text="Bàn điều khiển đặt giá" styleClass="partner-title"/>
                                    
                                    <HBox spacing="24" VBox.vgrow="ALWAYS" alignment="TOP_CENTER">
                                        <!-- Cột Đặt giá thủ công -->
                                        <VBox spacing="12" HBox.hgrow="ALWAYS">
                                            <Label text="Đặt giá thủ công" styleClass="field-label" style="-fx-font-size: 14px;"/>
                                            <HBox spacing="10" alignment="CENTER_LEFT">
                                                <TextField fx:id="txtBidAmount" promptText="Số tiền (VND)" styleClass="mail-field" HBox.hgrow="ALWAYS"/>
                                                <Button fx:id="btnBid" text="Đặt giá" onAction="#handleBid" styleClass="primary-btn"/>
                                            </HBox>
                                            <Label fx:id="lblBidHint" text="Giá đặt phải lớn hơn giá hiện tại + bước giá tối thiểu." styleClass="muted-text" wrapText="true"/>
                                        </VBox>

                                        <Separator orientation="VERTICAL"/>

                                        <!-- Cột Auto-bid tự động -->
                                        <VBox spacing="10" HBox.hgrow="ALWAYS">
                                            <Label text="Auto-bid tự động" styleClass="field-label" style="-fx-font-size: 14px;"/>
                                            <TextField fx:id="txtAutoBidMax" promptText="Giá tối đa (VND)" styleClass="mail-field"/>
                                            <TextField fx:id="txtAutoBidStep" promptText="Bước tăng (VND)" styleClass="mail-field"/>
                                            <HBox spacing="10">
                                                <Button text="Bật Auto-bid" onAction="#handleActivateAutoBid" styleClass="primary-btn"/>
                                                <Button text="Tắt" onAction="#handleDisableAutoBid" styleClass="secondary-btn-small"/>
                                            </HBox>
                                            <Label fx:id="lblAutoBidStatus" text="Auto-bid chưa được kích hoạt." styleClass="muted-text" wrapText="true"/>
                                        </VBox>
                                    </HBox>
                                </VBox>

                                <!-- Lịch sử đặt giá -->
                                <VBox spacing="12" styleClass="content-card" prefWidth="380" minWidth="380">
                                    <padding>
                                        <Insets top="20" right="20" bottom="20" left="20"/>
                                    </padding>
                                    <Label text="Lịch sử đặt giá" styleClass="partner-title"/>
                                    <ListView fx:id="lvBidHistory" prefHeight="180" VBox.vgrow="ALWAYS" styleClass="auction-history-list"/>
                                </VBox>
                            </HBox>

                            <!-- Hàng 2: Biểu đồ giá theo thời gian -->
                            <VBox spacing="12" styleClass="content-card">
                                <padding>
                                    <Insets top="20" right="20" bottom="20" left="20"/>
                                </padding>
                                <Label text="Biểu đồ giá theo thời gian (Realtime)" styleClass="partner-title"/>
                                <LineChart fx:id="priceChart"
                                           animated="false"
                                           createSymbols="true"
                                           legendVisible="false"
                                           prefHeight="360"
                                           minHeight="300"
                                           styleClass="auction-chart">
                                    <xAxis>
                                        <NumberAxis fx:id="xAxis" label="Thứ tự lượt bid"/>
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis fx:id="yAxis" label="Giá (VND)"/>
                                    </yAxis>
                                </LineChart>
                            </VBox>

                            <!-- Hàng 3: Cập nhật & Thông báo giới thiệu -->
                            <HBox spacing="18">
                                <VBox spacing="8" styleClass="content-card" HBox.hgrow="ALWAYS">
                                    <padding>
                                        <Insets top="14" right="16" bottom="14" left="16"/>
                                    </padding>
                                    <Label text="Realtime update" styleClass="partner-title" style="-fx-font-size: 14px;"/>
                                    <Label text="Màn hình nhận cập nhật theo observer nội bộ, không còn tự poll dữ liệu mỗi giây." styleClass="partner-text" wrapText="true" style="-fx-font-size: 12px;"/>
                                </VBox>
                                <VBox spacing="8" styleClass="content-card" HBox.hgrow="ALWAYS">
                                    <padding>
                                        <Insets top="14" right="16" bottom="14" left="16"/>
                                    </padding>
                                    <Label text="Notification" styleClass="partner-title" style="-fx-font-size: 14px;"/>
                                    <Label text="Khi bị outbid hoặc auto-bid chạy, thông báo sẽ xuất hiện ở đầu màn hình và popup." styleClass="partner-text" wrapText="true" style="-fx-font-size: 12px;"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>

