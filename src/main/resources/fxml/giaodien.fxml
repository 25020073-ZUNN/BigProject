                            <Button maxWidth="1.7976931348623157E308" onAction="#goToUserProfile" styleClass="primary-btn" text="Quản lý hồ sơ" />
                            <Button maxWidth="1.7976931348623157E308" onAction="#goToAuctionHistory" styleClass="secondary-btn" text="Lịch sử đấu giá" />
