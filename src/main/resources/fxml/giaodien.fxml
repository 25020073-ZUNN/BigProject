                                <StackPane prefHeight="175" styleClass="news-thumb">
                                    <ImageView fitHeight="175" fitWidth="368" preserveRatio="false">
                                        <clip>
                                            <Rectangle arcHeight="20" arcWidth="20" height="175" width="368" />
                                        </clip>
                                        <image>
                                            <Image url="@../images/news_mobile.jpg" />
                                        </image>
                                    </ImageView>
                                </StackPane>
                                <VBox spacing="6">
                                    <padding><Insets bottom="16" left="16" right="16" top="4" /></padding>
                                    <Label styleClass="news-title" text="Ra mắt giao diện theo dõi phiên đấu giá trên di động" wrapText="true" />
                                    <Label styleClass="news-text" text="Bản demo tập trung trải nghiệm theo dõi trạng thái, mức giá và thời gian." wrapText="true" />
                                </VBox>
                            </VBox>
                        </HBox>
                    </VBox>

