                            <TextField fx:id="quickUsernameField" promptText="Email hoặc tên đăng nhập" styleClass="mail-field" />
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <PasswordField fx:id="quickPasswordField" promptText="Mật khẩu" styleClass="mail-field" HBox.hgrow="ALWAYS" />
                                <TextField fx:id="visibleQuickPasswordField" managed="false" promptText="Mật khẩu" styleClass="mail-field" visible="false" HBox.hgrow="ALWAYS" />
                                <Button fx:id="toggleQuickPasswordButton" styleClass="password-eye-btn" text="👁" />
                            </HBox>

                            <Button fx:id="mainLoginButton" maxWidth="1.7976931348623157E308" onAction="#handleQuickLogin" styleClass="primary-btn" text="Đăng nhập hệ thống" />
                            <Button maxWidth="1.7976931348623157E308" onAction="#goToRegister" styleClass="secondary-btn" text="Tạo tài khoản mới" />

                            <Separator />

                            <Label styleClass="login-panel-note" text="✓  Theo dõi tài sản yêu thích&#10;✓  Nhận thông báo phiên mới&#10;✓  Quản lý hồ sơ tham gia10&#10;✓  An toàn &amp; bảo mật" wrapText="true" />
