                                        </clip>
                                        <image>
                                            <Image url="@../images/news_security.jpg" />
                                        </image>
                                    </ImageView>
                                </StackPane>
                                <VBox spacing="6">
                                    <padding><Insets bottom="16" left="16" right="16" top="4" /></padding>
                                    <Label styleClass="news-title" text="Mở thêm danh mục tài sản thanh lý cho doanh nghiệp" wrapText="true" />
                                    <Label styleClass="news-text" text="Hệ thống bổ sung nhóm tài sản mới, tăng số lượng phiên đấu giá trong quý II." wrapText="true" />
