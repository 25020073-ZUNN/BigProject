                                <Label styleClass="footer-title" text="Liên hệ" />
                                <Label styleClass="footer-text" text="📍  Cầu Giấy - Hà Nội&#10;📞  0398106007&#10;✉️  team6ltnc@gmail.com&#10;🕐  Trong giờ hành chính" wrapText="true" />
