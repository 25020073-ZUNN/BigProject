                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <padding><Insets bottom="22" left="22" right="22" top="22" /></padding>
                            <Label styleClass="stat-number" text="3" />
                            <Label styleClass="stat-text" text="Tài sản đang mở đấu giá" />
                        </VBox>

                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <padding><Insets bottom="22" left="22" right="22" top="22" /></padding>
                            <Label styleClass="stat-number" text="50+" />
                            <Label styleClass="stat-text" text="Người dùng tham gia" />
                        </VBox>

                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <padding><Insets bottom="22" left="22" right="22" top="22" /></padding>
                            <Label styleClass="stat-number" text="10" />
                            <Label styleClass="stat-text" text="Phiên đấu giá hoàn tất" />
                        </VBox>

                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <padding><Insets bottom="22" left="22" right="22" top="22" /></padding>
                            <Label styleClass="stat-number" text="90%" />
                            <Label styleClass="stat-text" text="Tỷ lệ hoạt động ổn định" />
                        </VBox>
                    </HBox>

                    <!-- ═══════════════════ AUCTIONS ═══════════════════ -->
                    <VBox spacing="24" styleClass="dark-section">
                        <padding><Insets bottom="48" left="56" right="56" top="48" /></padding>

                        <HBox alignment="CENTER_LEFT">
                            <Label styleClass="section-title" text="🔥  Tài sản sắp được đấu giá" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button onAction="#goToAuctionList" styleClass="secondary-btn" text="Xem tất cả  →" />
                        </HBox>

                        <FlowPane fx:id="upcomingAuctionsContainer" hgap="20" prefWrapLength="1260" vgap="20" />
                    </VBox>

