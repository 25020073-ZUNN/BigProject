                        <AnchorPane prefHeight="380" prefWidth="420" styleClass="hero-banner" HBox.hgrow="NEVER">
                            <children>
                                <VBox layoutX="32" layoutY="47.0" prefHeight="169.0" prefWidth="236.0" spacing="14">
                                    <Label styleClass="banner-chip" text="✨  DỰ ÁN MÔN HỌC - UET" />
                                    <Label styleClass="banner-title" text="ĐẤU GIÁ SỐ&#10;HỌC TẬP &amp;&#10;PHÁT TRIỂN" />
                                    <Label prefHeight="24.0" prefWidth="236.0" styleClass="banner-desc" text="Nền tảng thực nghiệm - Team 6 - UET" />
                                </VBox>
                                <HBox layoutX="32" layoutY="337.0" prefHeight="0.0" prefWidth="239.0" spacing="10">
                                    <Button styleClass="store-btn" text="📱  App Store" />
                                    <Button styleClass="store-btn" text="▶  Google Play" />
                                </HBox>
                            </children>
