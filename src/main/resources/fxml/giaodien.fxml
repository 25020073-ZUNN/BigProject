                                    <Label styleClass="news-title" text="Cập nhật quy trình tham gia đấu giá trực tuyến năm 2026" wrapText="true" />
                                    <Label styleClass="news-text" text="Nền tảng cập nhật luồng xác thực và ký quỹ để giúp người dùng thao tác nhanh hơn." wrapText="true" />
                                </VBox>
                            </VBox>

                            <VBox prefWidth="400" spacing="14" styleClass="news-card" HBox.hgrow="ALWAYS">
