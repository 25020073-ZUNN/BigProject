                        <VBox prefWidth="540" spacing="20" style="-fx-alignment: center-left;">
                            <Label styleClass="hero-small" text="🏛  HỆ THỐNG ĐẤU GIÁ TRỰC TUYẾN - TEAM 6 - UET" />

                            <Label styleClass="hero-title" text="Đấu giá trực tuyến&#10;Dự án học tập môn học&#10;Lập trình nâng cao" wrapText="true" />

                            <Label styleClass="hero-desc" text="Hệ thống đấu giá trực tuyến hiện đại được thiết kế và phát triển bởi Team 6 - UET. Sản phẩm phục vụ cho học tập và nghiên cứu công nghệ." wrapText="true" />

                            <HBox spacing="14" style="-fx-padding: 8 0 0 0;">
                                <Button onAction="#goToAuctionList" styleClass="primary-btn" text="🔍  Khám phá ngay" />
                            </HBox>

                            <HBox spacing="16" style="-fx-padding: 12 0 0 0;">
                                <VBox prefWidth="160" styleClass="mini-info-card">
                                    <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>
                                    <Label styleClass="mini-info-number" text="3" />
                                    <Label styleClass="mini-info-text" text="Phiên đang mở" />
                                </VBox>

                                <VBox prefWidth="160" styleClass="mini-info-card">
                                    <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>
                                    <Label styleClass="mini-info-number" text="90%" />
                                    <Label styleClass="mini-info-text" text="Hệ thống ổn định" />
                                </VBox>

                                <VBox prefWidth="160" styleClass="mini-info-card">
                                    <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>
                                    <Label styleClass="mini-info-number" text="24/7" />
                                    <Label styleClass="mini-info-text" text="Hỗ trợ liên tục" />
                                </VBox>
                            </HBox>
                        </VBox>

