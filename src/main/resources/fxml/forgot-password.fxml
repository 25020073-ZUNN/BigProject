<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.controller.HomeController"
            prefWidth="1380" prefHeight="860" stylesheets="@../style.css" styleClass="root">

    <!-- PHẦN TRÊN (TOP BAR): THANH ĐIỀU HƯỚNG -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="topbar">
            <padding><Insets top="12" right="36" bottom="12" left="36"/></padding>
            
            <VBox spacing="0">
                <Label text="AUREX" styleClass="logo-main"/>
                <Label text="AUCTION PLATFORM" styleClass="logo-sub"/>
            </VBox>
            
            <Region HBox.hgrow="ALWAYS"/>
            
            <Button text="Trang chủ" onAction="#goToHome" styleClass="nav-btn"/>
            <Button text="Tài sản đấu giá" onAction="#goToAuctionList" styleClass="nav-btn"/>
            <Button text="Phiên đấu giá" onAction="#goToSessions" styleClass="nav-btn"/>
            <Button text="Tin tức" onAction="#goToNews" styleClass="nav-btn"/>
            <Button text="Liên hệ" onAction="#goToContact" styleClass="nav-btn"/>
            
            <Button fx:id="loginButton" text="Đăng nhập" onAction="#goToLogin" styleClass="login-btn"/>
        </HBox>
    </top>

    <!-- PHẦN GIỮA (CENTER): KHU VỰC NỘI DUNG CHÍNH (FORM KHÔI PHỤC MẬT KHẨU) -->
    <center>
        <HBox spacing="0" alignment="CENTER">
            
            <!-- KHỐI BÊN TRÁI: THÔNG TIN GIỚI THIỆU & QUẢNG BÁ -->
            <VBox prefWidth="700" spacing="28" styleClass="auth-left">
                <padding><Insets top="52" right="52" bottom="52" left="52"/></padding>

                <Label text="Khôi phục mật khẩu tài khoản" styleClass="auth-title"/>
                <Label text="Vui lòng nhập tên tài khoản hoặc địa chỉ email đã đăng ký. Hệ thống sẽ gửi một mã xác nhận có thời hạn 5 phút để bạn đổi lại mật khẩu."
                       wrapText="true" styleClass="auth-desc"/>

                <!-- Banner đồ họa giới thiệu tính năng nổi bật -->
                <AnchorPane prefHeight="300" styleClass="auth-visual"
                            style="-fx-background-radius: 20;">
                    <children>
                        <Label layoutX="36" layoutY="36" text="🛡️  SECURITY ASSISTANCE" styleClass="banner-chip"/>
                        <Label layoutX="36" layoutY="80"
                               text="BẢO MẬT 2 LỚP&#10;MÃ XÁC THỰC OTP&#10;HẾT HẠN SAU 5 PHÚT"
                               styleClass="banner-title"/>
                        <Label layoutX="36" layoutY="200"
                               text="Đặt lại mật khẩu một cách an toàn thông qua mã xác nhận gửi tới email của bạn."
                               styleClass="banner-desc" wrapText="true"/>
                    </children>
                </AnchorPane>
            </VBox>

            <!-- KHỐI BÊN PHẢI: FORM ĐỔI MẬT KHẨU (FORGOT PASSWORD FORM) -->
            <VBox prefWidth="520" spacing="20" styleClass="auth-panel">
                <padding><Insets top="40" right="48" bottom="40" left="48"/></padding>

                <!-- Tiêu đề Form -->
                <Label text="🔑  Quên mật khẩu" styleClass="login-panel-title"/>
                <Label text="Lấy lại quyền truy cập tài khoản của bạn." styleClass="login-panel-text"/>

                <!-- Nhóm: Ô nhập Tên đăng nhập / Email & Nút gửi OTP -->
                <VBox spacing="8">
                    <Label text="Tên đăng nhập / Email" styleClass="field-label"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="forgotEmailOrUsernameField" promptText="Nhập tên đăng nhập hoặc email" styleClass="mail-field" HBox.hgrow="ALWAYS"/>
                        <Button text="Gửi mã OTP" onAction="#handleSendResetToken" styleClass="secondary-btn" prefWidth="120" style="-fx-font-size: 13px;"/>
                    </HBox>
                </VBox>

                <!-- Nhóm: Ô nhập Mã xác thực -->
                <VBox spacing="8">
                    <Label text="Mã xác thực OTP" styleClass="field-label"/>
                    <TextField fx:id="forgotTokenField" promptText="Nhập mã xác thực gồm 6 chữ số" styleClass="mail-field"/>
                </VBox>

                <!-- Nhóm: Ô nhập Mật khẩu mới -->
                <VBox spacing="8">
                    <Label text="Mật khẩu mới" styleClass="field-label"/>
                    <PasswordField fx:id="forgotNewPasswordField" promptText="Nhập mật khẩu mới (tối thiểu 8 ký tự)" styleClass="mail-field"/>
                </VBox>

                <!-- Nhóm: Nhập lại mật khẩu mới -->
                <VBox spacing="8">
                    <Label text="Xác nhận mật khẩu mới" styleClass="field-label"/>
                    <PasswordField fx:id="forgotConfirmPasswordField" promptText="Nhập lại mật khẩu mới" styleClass="mail-field"/>
                </VBox>

                <!-- Label hiển thị thông báo trạng thái -->
                <Label fx:id="forgotStatusLabel" text="" visible="false" managed="false" style="-fx-text-fill: #ff6b6b; -fx-font-size: 13px; -fx-font-weight: bold;" wrapText="true"/>

                <!-- Nút thao tác chính: Cập nhật mật khẩu -->
                <Button text="Đổi mật khẩu" maxWidth="1.7976931348623157E308"
                        onAction="#handleConfirmResetPassword" styleClass="primary-btn"/>

                <!-- Liên kết quay lại Đăng nhập -->
                <HBox alignment="CENTER" spacing="4">
                    <Label text="Nhớ mật khẩu?" styleClass="muted-text"/>
                    <Hyperlink text="Đăng nhập ngay" onAction="#goToLogin" styleClass="auth-link"/>
                </HBox>

                <!-- Đường kẻ phân cách -->
                <Separator/>

                <!-- Hộp lưu ý -->
                <VBox spacing="8" styleClass="auth-note-box">
                    <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                    <Label text="📌  Lưu ý bảo mật" styleClass="note-title"/>
                    <Label text="✓  Mã xác thực có hiệu lực trong vòng 5 phút.&#10;✓  Chúng tôi không bao giờ yêu cầu mật khẩu qua email.&#10;✓  Đặt mật khẩu mạnh có cả chữ, số và ký tự viết hoa."
                           wrapText="true" styleClass="login-panel-note"/>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
