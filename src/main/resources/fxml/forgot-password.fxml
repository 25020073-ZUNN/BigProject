<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="860" prefWidth="1380" styleClass="root" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.HomeController">

    <!-- PHẦN TRÊN (TOP BAR): THANH ĐIỀU HƯỚNG -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="topbar">
            <padding><Insets bottom="12" left="36" right="36" top="12" /></padding>
            
                            <HBox alignment="CENTER_LEFT" spacing="10">
                    <ImageView fitHeight="42" preserveRatio="true">
                        <image>
                            <Image url="@../images/d33812d6433b838f8d0f44c71287e89a.jpg" />
                        </image>
                    </ImageView>
                    <VBox spacing="0">
                        <Label style="-fx-font-size: 20px;" styleClass="logo-main" text="UET" />
                        <Label style="-fx-font-size: 9px;" styleClass="logo-sub" text="AUCTION PLATFORM" />
                    </VBox>
                </HBox>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <Button onAction="#goToHome" styleClass="nav-btn" text="Trang chủ" />
            <Button onAction="#goToAuctionList" styleClass="nav-btn" text="Tài sản đấu giá" />
            <Button onAction="#goToNews" styleClass="nav-btn" text="Tin tức" />
            <Button onAction="#goToContact" styleClass="nav-btn" text="Liên hệ" />
            
            <Button fx:id="themeToggleBtn" onAction="#toggleTheme" styleClass="theme-toggle-btn" text="🌙" />
            <Button fx:id="loginButton" onAction="#goToLogin" styleClass="login-btn" text="Đăng nhập" />
        </HBox>
    </top>

    <!-- PHẦN GIỮA (CENTER): KHU VỰC NỘI DUNG CHÍNH (FORM KHÔI PHỤC MẬT KHẨU) -->
    <center>
        <HBox alignment="CENTER" spacing="0">
            
            <!-- KHỐI BÊN TRÁI: THÔNG TIN GIỚI THIỆU & QUẢNG BÁ -->
            <VBox prefWidth="700" spacing="28" styleClass="auth-left">
                <padding><Insets bottom="52" left="52" right="52" top="52" /></padding>

                <Label styleClass="auth-title" text="Khôi phục mật khẩu tài khoản" />
                <Label styleClass="auth-desc" text="Vui lòng nhập tên tài khoản hoặc địa chỉ email đã đăng ký. Hệ thống sẽ gửi một mã xác nhận có thời hạn 5 phút để bạn đổi lại mật khẩu." wrapText="true" />

                <!-- Banner đồ họa giới thiệu tính năng nổi bật -->
                <AnchorPane prefHeight="300" style="-fx-background-radius: 20;" styleClass="auth-visual">
                    <children>
                        <Label layoutX="36" layoutY="36" styleClass="banner-chip" text="🛡️  SECURITY ASSISTANCE" />
                        <Label layoutX="36" layoutY="80" styleClass="banner-title" text="BẢO MẬT 2 LỚP&#10;MÃ XÁC THỰC OTP&#10;HẾT HẠN SAU 5 PHÚT" />
                        <Label layoutX="36" layoutY="200" styleClass="banner-desc" text="Đặt lại mật khẩu một cách an toàn thông qua mã xác nhận gửi tới email của bạn." wrapText="true" />
                    </children>
                </AnchorPane>
            </VBox>

            <!-- KHỐI BÊN PHẢI: FORM ĐỔI MẬT KHẨU (FORGOT PASSWORD FORM) -->
            <VBox prefWidth="520" spacing="20" styleClass="auth-panel">
                <padding><Insets bottom="40" left="48" right="48" top="40" /></padding>

                <!-- Tiêu đề Form -->
                <Label styleClass="login-panel-title" text="🔑  Quên mật khẩu" />
                <Label styleClass="login-panel-text" text="Lấy lại quyền truy cập tài khoản của bạn." />

                <!-- Nhóm: Ô nhập Tên đăng nhập / Email & Nút gửi OTP -->
                <VBox spacing="8">
                    <Label styleClass="field-label" text="Email" />
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <TextField fx:id="forgotEmailOrUsernameField" promptText="example@gmail.com" styleClass="mail-field" HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleSendResetToken" prefWidth="120" style="-fx-font-size: 13px;" styleClass="secondary-btn" text="Gửi mã OTP" />
                    </HBox>
                </VBox>

                <!-- Nhóm: Ô nhập Mã xác thực -->
                <VBox spacing="8">
                    <Label styleClass="field-label" text="Mã xác thực OTP" />
                    <TextField fx:id="forgotTokenField" promptText="Nhập mã xác thực gồm 6 chữ số" styleClass="mail-field" />
                </VBox>

                <!-- Nhóm: Ô nhập Mật khẩu mới -->
                <VBox spacing="8">
                    <Label styleClass="field-label" text="Mật khẩu mới" />
                    <PasswordField fx:id="forgotNewPasswordField" promptText="Nhập mật khẩu mới (tối thiểu 8 ký tự)" styleClass="mail-field" />
                </VBox>

                <!-- Nhóm: Nhập lại mật khẩu mới -->
                <VBox spacing="8">
                    <Label styleClass="field-label" text="Xác nhận mật khẩu mới" />
                    <PasswordField fx:id="forgotConfirmPasswordField" promptText="Nhập lại mật khẩu mới" styleClass="mail-field" />
                </VBox>

                <!-- Label hiển thị thông báo trạng thái -->
                <Label fx:id="forgotStatusLabel" managed="false" style="-fx-text-fill: #ff6b6b; -fx-font-size: 13px; -fx-font-weight: bold;" text="" visible="false" wrapText="true" />

                <!-- Nút thao tác chính: Cập nhật mật khẩu -->
                <Button maxWidth="1.7976931348623157E308" onAction="#handleConfirmResetPassword" styleClass="primary-btn" text="Đổi mật khẩu" />

                <!-- Liên kết quay lại Đăng nhập -->
                <HBox alignment="CENTER" spacing="4">
                    <Label styleClass="muted-text" text="Nhớ mật khẩu?" />
                    <Hyperlink onAction="#goToLogin" styleClass="auth-link" text="Đăng nhập ngay" />
                </HBox>

                <!-- Đường kẻ phân cách -->
                <Separator />

                <!-- Hộp lưu ý -->
                <VBox spacing="8" styleClass="auth-note-box">
                    <padding><Insets bottom="14" left="16" right="16" top="14" /></padding>
                    <Label styleClass="note-title" text="📌  Lưu ý bảo mật" />
                    <Label styleClass="login-panel-note" text="✓  Mã xác thực có hiệu lực trong vòng 5 phút.&#10;✓  Chúng tôi không bao giờ yêu cầu mật khẩu qua email.&#10;✓  Đặt mật khẩu mạnh có cả chữ, số và ký tự viết hoa." wrapText="true" />
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
