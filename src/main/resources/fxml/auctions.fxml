<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>

<!-- 1.Phần đầu ( Root ) và Cấu hình chung   -->

<BorderPane prefHeight="900" prefWidth="1380" styleClass="root" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.HomeController">
<!--2.Vùng  đầu trang .....Khu vực này chứa  thanh điều hướng (Navigation Bar) và phần tiêu đề giới thiệu. Tất cả được bọc trong một <VBox>-->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="18" styleClass="topbar">
            <padding>
                <Insets bottom="14" left="28" right="28" top="14" />
            </padding>

                            <HBox alignment="CENTER_LEFT" spacing="10">
                    <ImageView fitHeight="42" preserveRatio="true">
                        <image>
                            <Image url="@../images/logouet1.png" />
                        </image>
                    </ImageView>
                    <VBox spacing="0">
                        <Label style="-fx-font-size: 20px;" styleClass="logo-main" text="UET" />
                        <Label style="-fx-font-size: 9px;" styleClass="logo-sub" text="AUCTION PLATFORM" />
                    </VBox>
                </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <Button onAction="#goToHome" prefHeight="34.0" prefWidth="115.0" styleClass="nav-btn" text="Trang chủ" />
            <Button onAction="#goToAuctionList" prefHeight="34.0" prefWidth="173.0" styleClass="nav-btn" text="Tài sản đấu giá" />
            <Button onAction="#goToNews" styleClass="nav-btn" text="Tin tức" />
            <Button onAction="#goToContact" styleClass="nav-btn" text="Liên hệ" />
            <Button fx:id="themeToggleBtn" onAction="#toggleTheme" styleClass="theme-toggle-btn" text="🌙" />
            <Button fx:id="loginButton" onAction="#goToLogin" styleClass="login-btn" text="Đăng nhập" />
        </HBox>
    </top>

<!--3.Vùng  thân trang    -->
    <center>
        <VBox spacing="22" styleClass="page-section">
            <padding>
                <Insets bottom="30" left="42" right="42" top="30" />
            </padding>

            <VBox spacing="10">
                <Label styleClass="section-title-dark" text="Tạo tài khoản mới" />
                <Label prefHeight="18.0" prefWidth="774.0" styleClass="section-subtitle" text="Đăng ký tài khoản để tham gia đấu giá, nhận thông báo tài sản mới và quản lý lịch sử tham gia." wrapText="true" />
            </VBox>

            <HBox prefHeight="656.0" prefWidth="1296.0" spacing="24">
                <VBox prefWidth="860" spacing="20" styleClass="register-panel">
                    <padding>
                        <Insets bottom="26" left="26" right="26" top="26" />
                    </padding>

                    <Label prefHeight="28.0" prefWidth="299.0" styleClass="login-panel-title" text="Thông tin đăng ký" />

                    <GridPane hgap="18" prefHeight="282.0" prefWidth="793.0" vgap="16">
                        <Label styleClass="field-label" text="Họ và tên" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField prefHeight="43.0" prefWidth="200.0" promptText="Nhập họ và tên" styleClass="mail-field" GridPane.columnIndex="0" GridPane.rowIndex="1" />

                        <Label prefHeight="17.0" prefWidth="275.0" styleClass="field-label" text="Số điện thoại" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <TextField prefHeight="43.0" prefWidth="352.0" promptText="Nhập số điện thoại" styleClass="mail-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label styleClass="field-label" text="Loại tài khoản" GridPane.columnIndex="0" GridPane.rowIndex="2" />

                        <Label styleClass="field-label" text="Loại tài khoản" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label styleClass="field-label" text="Địa chỉ" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                        <TextField prefHeight="43.0" prefWidth="371.0" promptText="Nhập địa chỉ liên hệ" styleClass="mail-field" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                  <ButtonBar prefHeight="51.0" prefWidth="271.0" GridPane.rowIndex="3">
                     <buttons>
                              <ComboBox prefHeight="51.0" prefWidth="302.0" promptText="Chọn loại tài khoản" styleClass="mail-field" />
                     </buttons></ButtonBar>
                  <columnConstraints>
                     <ColumnConstraints maxWidth="299.0" minWidth="204.0" prefWidth="289.0" />
                     <ColumnConstraints maxWidth="362.0" minWidth="267.0" prefWidth="277.0" />
                  </columnConstraints>
                  <rowConstraints>
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                  </rowConstraints>
                    </GridPane>

                    <VBox spacing="10">
                        <CheckBox prefHeight="20.0" prefWidth="385.0" styleClass="check-auth" text="Tôi đồng ý với điều khoản sử dụng và chính sách bảo mật" />
                        <CheckBox prefHeight="20.0" prefWidth="376.0" styleClass="check-auth" text="Tôi muốn nhận thông báo về phiên đấu giá và tài sản mới" />
                    </VBox>

                    <HBox prefHeight="39.0" prefWidth="806.0" spacing="12">
                        <Button styleClass="primary-btn" text="Tạo tài khoản" />
                        <Button prefHeight="45.0" prefWidth="242.0" styleClass="secondary-btn" text="Làm mới thông tin" />
                    </HBox>
                </VBox>

                <VBox prefWidth="410" spacing="16">
                    <VBox prefHeight="168.0" prefWidth="440.0" spacing="14" styleClass="side-info-card">
                        <padding>
                            <Insets bottom="22" left="22" right="22" top="22" />
                        </padding>

                        <Label styleClass="partner-title" text="Quy trình kích hoạt tài khoản" />
                        <Label styleClass="partner-text" text="1. Điền thông tin cá nhân&#10;2. Xác thực email / số điện thoại&#10;3. Hoàn thiện hồ sơ&#10;4. Bắt đầu tham gia đấu giá" wrapText="true" />
                    </VBox>

                    <VBox prefHeight="164.0" prefWidth="442.0" spacing="14" styleClass="side-info-card">
                        <padding>
                            <Insets bottom="22" left="22" right="22" top="22" />
                        </padding>

                        <Label styleClass="partner-title" text="Lợi ích khi đăng ký">
                     <textFill>
                        <LinearGradient endX="1.0" endY="1.0">
                           <stops>
                              <Stop>
                                 <color>
                                    <Color red="0.4880000054836273" green="0.7800850868225098" blue="0.800000011920929" />
                                 </color>
                              </Stop>
                              <Stop offset="1.0">
                                 <color>
                                    <Color red="1.0" green="1.0" blue="1.0" />
                                 </color>
                              </Stop>
                           </stops>
                        </LinearGradient>
                     </textFill></Label>
                        <Label styleClass="partner-text" text="• Theo dõi tài sản yêu thích&#10;• Nhận thông báo nhắc lịch&#10;• Quản lý lịch sử tham gia&#10;• Truy cập hồ sơ và biên bản" wrapText="true" />
                    </VBox>

                    <VBox spacing="14" styleClass="side-info-card-dark">
                        <padding>
                            <Insets bottom="22" left="22" right="22" top="22" />
                        </padding>

                        <Label styleClass="section-title" text="Đã có tài khoản?" />
                        <Label styleClass="footer-text" text="Đăng nhập để tiếp tục theo dõi các phiên đang mở và trạng thái hồ sơ." wrapText="true" />
                        <Hyperlink onAction="#goToLogin" styleClass="auth-link-light" text="Chuyển sang trang đăng nhập" />
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
