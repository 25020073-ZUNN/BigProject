<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<!-- 1.Phần đầu ( Root ) và Cấu hình chung   -->

<BorderPane prefHeight="900" prefWidth="1380" styleClass="root" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.HomeController">
<!--2.Vùng  đầu trang .....Khu vực này chứa  thanh điều hướng (Navigation Bar) và phần tiêu đề giới thiệu. Tất cả được bọc trong một <VBox>-->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="18" styleClass="topbar">
            <padding>
                <Insets bottom="14" left="28" right="28" top="14" />
            </padding>

                            <HBox alignment="CENTER_LEFT" spacing="10">
                    <ImageView fitHeight="42" preserveRatio="true">
                        <image>
                            <Image url="@../images/d33812d6433b838f8d0f44c71287e89a.jpg" />
                        </image>
                    </ImageView>
                    <VBox spacing="0">
                        <Label style="-fx-font-size: 20px;" styleClass="logo-main" text="UET" />
                        <Label style="-fx-font-size: 9px;" styleClass="logo-sub" text="AUCTION PLATFORM" />
                    </VBox>
                </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <Button onAction="#goToHome" styleClass="nav-btn" text="Trang chủ" />
            <Button onAction="#goToAuctionList" styleClass="nav-btn" text="Tài sản đấu giá" />
            <Button onAction="#goToNews" styleClass="nav-btn" text="Tin tức" />
            <Button onAction="#goToContact" styleClass="nav-btn" text="Liên hệ" />
            <Button fx:id="themeToggleBtn" onAction="#toggleTheme" styleClass="theme-toggle-btn" text="🌙" />
            <Button fx:id="loginButton" onAction="#goToLogin" styleClass="login-btn" text="Đăng nhập" />
        </HBox>
    </top>

<!--3.Vùng  thân trang    -->
    <center>
        <VBox spacing="22" styleClass="page-section">
            <padding>
                <Insets bottom="30" left="42" right="42" top="30" />
            </padding>

            <VBox spacing="10">
                <Label styleClass="section-title-dark" text="Tạo tài khoản mới" />
                <Label styleClass="section-subtitle" text="Đăng ký tài khoản để tham gia đấu giá, nhận thông báo tài sản mới và quản lý lịch sử tham gia." wrapText="true" />
            </VBox>

            <HBox spacing="24">
                <VBox prefWidth="860" spacing="20" styleClass="register-panel">
                    <padding>
                        <Insets bottom="26" left="26" right="26" top="26" />
                    </padding>

                    <Label styleClass="login-panel-title" text="Thông tin đăng ký" />

                    <GridPane hgap="18" prefHeight="390.0" prefWidth="806.0" vgap="16">
                        <Label styleClass="field-label" text="Họ và tên" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField prefHeight="43.0" prefWidth="223.0" promptText="Nhập họ và tên" styleClass="mail-field" GridPane.columnIndex="0" GridPane.rowIndex="1" />

                        <Label styleClass="field-label" text="Số điện thoại" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <TextField prefHeight="43.0" prefWidth="251.0" promptText="Nhập số điện thoại" styleClass="mail-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label styleClass="field-label" text="Email" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <TextField promptText="example@gmail.com" styleClass="mail-field" GridPane.columnIndex="0" GridPane.rowIndex="3" />

                        <Label styleClass="field-label" text="Loại tài khoản" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <ComboBox promptText="Chọn loại tài khoản" styleClass="mail-field" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <Label styleClass="field-label" text="CMND/CCCD" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <TextField promptText="Nhập số giấy tờ" styleClass="mail-field" GridPane.columnIndex="0" GridPane.rowIndex="5" />

                        <Label styleClass="field-label" text="Địa chỉ" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                        <TextField promptText="Nhập địa chỉ liên hệ" styleClass="mail-field" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                        <Label styleClass="field-label" text="Mật khẩu" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                        <PasswordField promptText="Nhập mật khẩu" styleClass="mail-field" GridPane.columnIndex="0" GridPane.rowIndex="7" />

                        <Label styleClass="field-label" text="Xác nhận mật khẩu" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                        <PasswordField promptText="Nhập lại mật khẩu" styleClass="mail-field" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                  <columnConstraints>
                     <ColumnConstraints />
                     <ColumnConstraints />
                  </columnConstraints>
                  <rowConstraints>
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                  </rowConstraints>
                    </GridPane>

                    <VBox spacing="10">
                        <CheckBox prefHeight="20.0" prefWidth="474.0" styleClass="check-auth" text="Tôi đồng ý với điều khoản sử dụng và chính sách bảo mật" />
                        <CheckBox prefHeight="20.0" prefWidth="508.0" styleClass="check-auth" text="Tôi muốn nhận thông báo về phiên đấu giá và tài sản mới" />
                    </VBox>

                    <HBox spacing="12">
                        <Button styleClass="primary-btn" text="Tạo tài khoản" />
                        <Button styleClass="secondary-btn" text="Làm mới thông tin" />
                    </HBox>
                </VBox>

                <VBox prefWidth="410" spacing="16">
                    <VBox prefHeight="168.0" prefWidth="442.0" spacing="14" styleClass="side-info-card">
                        <padding>
                            <Insets bottom="22" left="22" right="22" top="22" />
                        </padding>

                        <Label styleClass="partner-title" text="Quy trình kích hoạt tài khoản" />
                        <Label styleClass="partner-text" text="1. Điền thông tin cá nhân&#10;2. Xác thực email / số điện thoại&#10;3. Hoàn thiện hồ sơ&#10;4. Bắt đầu tham gia đấu giá" wrapText="true" />
                    </VBox>

                    <VBox prefHeight="164.0" prefWidth="442.0" spacing="14" styleClass="side-info-card">
                        <padding>
                            <Insets bottom="22" left="22" right="22" top="22" />
                        </padding>

                        <Label styleClass="partner-title" text="Lợi ích khi đăng ký" />
                        <Label styleClass="partner-text" text="• Theo dõi tài sản yêu thích&#10;• Nhận thông báo nhắc lịch&#10;• Quản lý lịch sử tham gia&#10;• Truy cập hồ sơ và biên bản" wrapText="true" />
                    </VBox>

                    <VBox spacing="14" styleClass="side-info-card-dark">
                        <padding>
                            <Insets bottom="22" left="22" right="22" top="22" />
                        </padding>

                        <Label styleClass="section-title" text="Đã có tài khoản?" />
                        <Label styleClass="footer-text" text="Đăng nhập để tiếp tục theo dõi các phiên đang mở và trạng thái hồ sơ." wrapText="true" />
                        <Hyperlink onAction="#goToLogin" styleClass="auth-link-light" text="Chuyển sang trang đăng nhập" />
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
