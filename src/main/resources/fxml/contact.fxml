<?xml version="1.0" encoding="UTF-8"?>
<!--liên hệ-->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.controller.HomeController"
            prefWidth="1380"
            prefHeight="920"
            stylesheets="@../style.css"
            styleClass="root">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="topbar">
                <padding>
                    <Insets top="12" right="36" bottom="12" left="36"/>
                </padding>

                                <HBox alignment="CENTER_LEFT" spacing="10">
                    <ImageView fitHeight="42" preserveRatio="true">
                        <image>
                            <Image url="@../images/d33812d6433b838f8d0f44c71287e89a.jpg"/>
                        </image>
                    </ImageView>
                    <VBox spacing="0">
                        <Label text="UET" styleClass="logo-main" style="-fx-font-size: 20px;"/>
                        <Label text="AUCTION PLATFORM" styleClass="logo-sub" style="-fx-font-size: 9px;"/>
                    </VBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Trang chủ" onAction="#goToHome" styleClass="nav-btn"/>
                <Button text="Tài sản đấu giá" onAction="#goToAuctionList" styleClass="nav-btn"/>
                <Button text="Tin tức" onAction="#goToNews" styleClass="nav-btn"/>
                <Button text="Liên hệ" onAction="#goToContact" styleClass="nav-btn-active"/>

                <Label fx:id="clockLabel" text="08:30:12&#10;07/04/2026" styleClass="clock-label"/>

                <Button fx:id="loginButton" text="Đăng nhập" onAction="#goToLogin" styleClass="login-btn"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="main-scroll" cache="true" cacheHint="SPEED">
            <content>
                <VBox spacing="30" cache="true" cacheHint="SPEED">

                    <!-- HERO SECTION -->
                    <!-- HERO: Tiêu đề trang liên hệ -->
                    <VBox spacing="12" styleClass="page-hero-small">
                        <padding>
                            <Insets top="44" right="48" bottom="44" left="48"/>
                        </padding>
                        <Label text="LIÊN HỆ VỚI CHÚNG TÔI" styleClass="hero-small"/>
                        <Label text="Hỗ trợ &amp; Phản hồi khách hàng" styleClass="hero-title"/>
                        <Label text="Chúng tôi luôn sẵn sàng lắng nghe và hỗ trợ bạn trong quá trình sử dụng nền tảng đấu giá."
                               styleClass="hero-desc"/>
                    </VBox>


                    <!-- MAIN CONTENT -->
                    <!-- NỘI DUNG CHÍNH: Form liên hệ + Thông tin -->
                    <HBox spacing="30">
                        <padding>
                            <Insets top="0" right="48" bottom="44" left="48"/>
                        </padding>

                        <!-- LEFT: CONTACT FORM -->
                        <VBox spacing="20" HBox.hgrow="ALWAYS" styleClass="content-card">
                            <padding>
                                <Insets top="30" right="30" bottom="30" left="30"/>
                            </padding>

                            <Label text="Gửi lời nhắn cho chúng tôi" styleClass="section-title-dark"/>
                            <Label text="Vui lòng điền thông tin vào mẫu bên dưới, chúng tôi sẽ phản hồi trong vòng 24h."
                                   styleClass="muted-text"/>

                            <VBox spacing="8">
                                <Label text="Họ và tên" styleClass="field-label"/>
                                <TextField promptText="Nhập họ và tên của bạn" styleClass="mail-field"/>
                            </VBox>

                            <HBox spacing="20">
                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                    <Label text="Email" styleClass="field-label"/>
                                    <TextField promptText="example@gmail.com" styleClass="mail-field"/>
                                </VBox>
                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                    <Label text="Số điện thoại" styleClass="field-label"/>
                                    <TextField promptText="Nhập số điện thoại" styleClass="mail-field"/>
                                </VBox>
                            </HBox>

                            <VBox spacing="8">
                                <Label text="Chủ đề" styleClass="field-label"/>
                                <TextField promptText="Cần hỗ trợ về vấn đề gì?" styleClass="mail-field"/>
                            </VBox>

                            <VBox spacing="8">
                                <Label text="Nội dung lời nhắn" styleClass="field-label"/>
                                <TextArea promptText="Viết nội dung tin nhắn của bạn tại đây..."
                                          prefHeight="150"
                                          wrapText="true"
                                          styleClass="mail-field"/>
                            </VBox>

                            <Button text="Gửi lời nhắn ngay"
                                    onAction="#handleComingSoon"
                                    maxWidth="200"
                                    styleClass="primary-btn"/>
                        </VBox>

                        <!-- RIGHT:  CONTACT INFO -->
                        <VBox spacing="20" prefWidth="420">

                            <!-- INFO CARD 1 -->
                            <VBox spacing="15" styleClass="side-info-card">
                                <padding>
                                    <Insets top="24" right="24" bottom="24" left="24"/>
                                </padding>
                                <Label text="Thông tin liên hệ" styleClass="section-title-dark"/>

                                <VBox spacing="12">
                                    <HBox spacing="10">
                                        <Label text="📍" style="-fx-font-size: 18px;"/>
                                        <VBox>
                                            <Label text="Địa chỉ trụ sở" styleClass="section-subtitle-bold"/>
                                            <Label text="Cầu Giấy - Hà Nội"
                                                   wrapText="true" styleClass="muted-text"/>
                                        </VBox>
                                    </HBox>

                                    <HBox spacing="10">
                                        <Label text="📞" style="-fx-font-size: 18px;"/>
                                        <VBox>
                                            <Label text="Số điện thoại" styleClass="section-subtitle-bold"/>
                                            <Label text="0398106007" styleClass="muted-text"/>
                                        </VBox>
                                    </HBox>

                                    <HBox spacing="10">
                                        <Label text="✉️" style="-fx-font-size: 18px;"/>
                                        <VBox>
                                            <Label text="Email phản hồi" styleClass="section-subtitle-bold"/>
                                            <Label text="team6ltnc@gmail.com" styleClass="muted-text"/>
                                        </VBox>
                                    </HBox>
                                </VBox>
                            </VBox>

                            <!-- INFO CARD 2 -->
                            <VBox spacing="15" styleClass="side-info-card-dark">
                                <padding>
                                    <Insets top="24" right="24" bottom="24" left="24"/>
                                </padding>
                                <Label text="Thời gian làm việc" styleClass="section-title"/>
                                <VBox spacing="10">
                                    <HBox>
                                        <Label text="Giờ hoạt động:" styleClass="banner-desc" prefWidth="120"/>
                                        <Label text="Trong giờ hành chính" styleClass="banner-title" style="-fx-font-size: 14px;"/>
                                    </HBox>
                                    <HBox>
                                        <Label text="Các ngày:" styleClass="banner-desc" prefWidth="120"/>
                                        <Label text="Thứ 2 - Thứ 6" styleClass="banner-title" style="-fx-font-size: 14px;"/>
                                    </HBox>
                                    <HBox>
                                        <Label text="Cuối tuần:" styleClass="banner-desc" prefWidth="120"/>
                                        <Label text="Nghỉ" styleClass="banner-title" style="-fx-font-size: 14px;"/>
                                    </HBox>
                                </VBox>
                            </VBox>

                            <!-- FAQ LINK -->
                            <VBox spacing="15" styleClass="auth-note-box">
                                <padding>
                                    <Insets top="20" right="20" bottom="20" left="20"/>
                                </padding>
                                <Label text="Câu hỏi thường gặp?" styleClass="section-subtitle-bold"/>
                                <Label text="Bạn có thể tìm thấy câu trả lời nhanh chóng cho các thắc mắc phổ biến tại trung tâm trợ giúp của chúng tôi."
                                       wrapText="true" styleClass="muted-text"/>
                                <Button text="Xem FAQ" styleClass="secondary-btn-small"/>
                            </VBox>
                        </VBox>
                    </HBox>

                    <!-- FOOTER -->
                    <!-- FOOTER -->
                    <VBox spacing="22" styleClass="footer">
                        <padding>
                            <Insets top="36" right="48" bottom="30" left="48"/>
                        </padding>

                        <HBox spacing="60">
                            <VBox spacing="10" prefWidth="280">
                                <Label text="Team 6 - UET" styleClass="footer-title"/>
                                <Label text="Dự án đấu giá trực tuyến&#10;Môn học: Lập trình nâng cao&#10;Trường Đại học Công nghệ - ĐHQGHN"
                                       wrapText="true" styleClass="footer-text"/>
                            </VBox>

                            <VBox spacing="10" prefWidth="220">
                                <Label text="Về chúng tôi" styleClass="footer-title"/>
                                <Label text="Giới thiệu&#10;Quy chế hoạt động&#10;Hướng dẫn sử dụng"
                                       wrapText="true" styleClass="footer-text"/>
                            </VBox>

                            <VBox spacing="10" prefWidth="220">
                                <Label text="Chính sách" styleClass="footer-title"/>
                                <Label text="Bảo mật&#10;Điều khoản sử dụng&#10;Quy định đấu giá"
                                       wrapText="true" styleClass="footer-text"/>
                            </VBox>

                            <VBox spacing="10" prefWidth="260">
                                <Label text="Liên hệ nhanh" styleClass="footer-title"/>
                                <Label text="📍  Cầu Giấy - Hà Nội&#10;📞  0398106007&#10;✉️  team6ltnc@gmail.com&#10;🕐  Trong giờ hành chính"
                                       wrapText="true" styleClass="footer-text"/>
                            </VBox>
                        </HBox>

                        <Separator styleClass="footer-separator"/>
                        <Label text="Copyright 2026 © Team 6 - UET. All rights reserved."
                               styleClass="copyright"/>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
