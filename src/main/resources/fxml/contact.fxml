<?xml version="1.0" encoding="UTF-8"?>

<!--liên hệ-->

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="920" prefWidth="1380" styleClass="root" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.HomeController">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="topbar">
                <padding>
                    <Insets bottom="12" left="36" right="36" top="12" />
                </padding>

                                <HBox alignment="CENTER_LEFT" spacing="10">
                    <ImageView fitHeight="42" preserveRatio="true">
                        <image>
                            <Image url="@../images/logouet1.png" />
                        </image>
                    </ImageView>
                    <VBox spacing="0">
                        <Label style="-fx-font-size: 20px;" styleClass="logo-main" text="UET" />
                        <Label style="-fx-font-size: 9px;" styleClass="logo-sub" text="AUCTION PLATFORM" />
                    </VBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <Button onAction="#goToHome" styleClass="nav-btn" text="Trang chủ" />
                <Button onAction="#goToAuctionList" styleClass="nav-btn" text="Tài sản đấu giá" />
                <Button onAction="#goToNews" styleClass="nav-btn" text="Tin tức" />
                <Button onAction="#goToContact" styleClass="nav-btn-active" text="Liên hệ" />

                <Label fx:id="clockLabel" styleClass="clock-label" text="08:30:12&#10;07/04/2026" />

                <Button fx:id="themeToggleBtn" onAction="#toggleTheme" styleClass="theme-toggle-btn" text="🌙" />
                <Button fx:id="loginButton" onAction="#goToLogin" styleClass="login-btn" text="Đăng nhập" />
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane cache="true" cacheHint="SPEED" fitToWidth="true" hbarPolicy="NEVER" styleClass="main-scroll">
            <content>
                <VBox cache="true" cacheHint="SPEED" spacing="30">

                    <!-- HERO SECTION -->
                    <!-- HERO: Tiêu đề trang liên hệ -->
                    <VBox spacing="12" styleClass="page-hero-small">
                        <padding>
                            <Insets bottom="44" left="48" right="48" top="44" />
                        </padding>
                        <Label styleClass="hero-small" text="LIÊN HỆ VỚI CHÚNG TÔI" />
                        <Label styleClass="hero-title" text="Hỗ trợ &amp; Phản hồi khách hàng" />
                        <Label styleClass="hero-desc" text="Chúng tôi luôn sẵn sàng lắng nghe và hỗ trợ bạn trong quá trình sử dụng nền tảng đấu giá." />
                    </VBox>


                    <!-- MAIN CONTENT -->
                    <!-- NỘI DUNG CHÍNH: Form liên hệ + Thông tin -->
                    <HBox spacing="30">
                        <padding>
                            <Insets bottom="44" left="48" right="48" top="0" />
                        </padding>

                        <!-- LEFT: CONTACT FORM -->
                        <VBox spacing="20" styleClass="content-card" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets bottom="30" left="30" right="30" top="30" />
                            </padding>

                            <Label styleClass="section-title-dark" text="Gửi lời nhắn cho chúng tôi" />
                            <Label styleClass="muted-text" text="Vui lòng điền thông tin vào mẫu bên dưới, chúng tôi sẽ phản hồi trong vòng 24h." />

                            <VBox spacing="8">
                                <Label styleClass="field-label" text="Họ và tên" />
                                <TextField promptText="Nhập họ và tên của bạn" styleClass="mail-field" />
                            </VBox>

                            <HBox spacing="20">
                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                    <Label styleClass="field-label" text="Email" />
                                    <TextField promptText="example@gmail.com" styleClass="mail-field" />
                                </VBox>
                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                    <Label styleClass="field-label" text="Số điện thoại" />
                                    <TextField promptText="Nhập số điện thoại" styleClass="mail-field" />
                                </VBox>
                            </HBox>

                            <VBox spacing="8">
                                <Label styleClass="field-label" text="Vấn đề" />
                                <TextField promptText="Cần hỗ trợ về vấn đề gì?" styleClass="mail-field" />
                            </VBox>

                            <VBox spacing="8">
                                <Label styleClass="field-label" text="Nội dung lời nhắn" />
                                <TextArea prefHeight="150" promptText="Viết nội dung tin nhắn của bạn tại đây..." styleClass="mail-field" wrapText="true" />
                            </VBox>

                            <Button maxWidth="200" onAction="#handleComingSoon" styleClass="primary-btn" text="Gửi lời nhắn ngay" />
                        </VBox>

                        <!-- RIGHT:  CONTACT INFO -->
                        <VBox prefWidth="420" spacing="20">

                            <!-- INFO CARD 1 -->
                            <VBox spacing="15" styleClass="side-info-card">
                                <padding>
                                    <Insets bottom="24" left="24" right="24" top="24" />
                                </padding>
                                <Label styleClass="section-title-dark" text="Thông tin liên hệ" />

                                <VBox spacing="12">
                                    <HBox spacing="10">
                                        <Label style="-fx-font-size: 18px;" text="📍" />
                                        <VBox>
                                            <Label styleClass="section-subtitle-bold" text="Địa chỉ trụ sở" />
                                            <Label styleClass="muted-text" text="Cầu Giấy - Hà Nội" wrapText="true" />
                                        </VBox>
                                    </HBox>

                                    <HBox spacing="10">
                                        <Label style="-fx-font-size: 18px;" text="📞" />
                                        <VBox>
                                            <Label styleClass="section-subtitle-bold" text="Số điện thoại" />
                                            <Label styleClass="muted-text" text="0398106007" />
                                        </VBox>
                                    </HBox>

                                    <HBox spacing="10">
                                        <Label style="-fx-font-size: 18px;" text="✉️" />
                                        <VBox>
                                            <Label styleClass="section-subtitle-bold" text="Email phản hồi" />
                                            <Label styleClass="muted-text" text="team6ltnc@gmail.com" />
                                        </VBox>
                                    </HBox>
                                </VBox>
                            </VBox>

                            <!-- INFO CARD 2 -->
                            <VBox spacing="15" styleClass="side-info-card-dark">
                                <padding>
                                    <Insets bottom="24" left="24" right="24" top="24" />
                                </padding>
                                <Label styleClass="section-title" text="Thời gian làm việc" />
                                <VBox spacing="10">
                                    <HBox>
                                        <Label prefWidth="120" styleClass="banner-desc" text="Giờ hoạt động:" />
                                        <Label style="-fx-font-size: 14px;" styleClass="banner-title" text="Trong giờ hành chính" />
                                    </HBox>
                                    <HBox>
                                        <Label prefWidth="120" styleClass="banner-desc" text="Các ngày:" />
                                        <Label style="-fx-font-size: 14px;" styleClass="banner-title" text="Thứ 2 - Thứ 6" />
                                    </HBox>
                                    <HBox>
                                        <Label prefWidth="120" styleClass="banner-desc" text="Cuối tuần:" />
                                        <Label style="-fx-font-size: 14px;" styleClass="banner-title" text="Nghỉ" />
                                    </HBox>
                                </VBox>
                            </VBox>

                            <!-- FAQ LINK -->
                            <VBox spacing="15" styleClass="auth-note-box">
                                <padding>
                                    <Insets bottom="20" left="20" right="20" top="20" />
                                </padding>
                                <Label styleClass="section-subtitle-bold" text="Câu hỏi thường gặp?" />
                                <Label styleClass="muted-text" text="Bạn có thể tìm thấy câu trả lời nhanh chóng cho các thắc mắc phổ biến tại trung tâm trợ giúp của chúng tôi." wrapText="true" />
                                <Button styleClass="secondary-btn-small" text="Xem FAQ" />
                            </VBox>
                        </VBox>
                    </HBox>

                    <!-- FOOTER -->
                    <!-- FOOTER -->
                    <VBox spacing="22" styleClass="footer">
                        <padding>
                            <Insets bottom="30" left="48" right="48" top="36" />
                        </padding>

                        <HBox spacing="60">
                            <VBox prefWidth="280" spacing="10">
                                <Label styleClass="footer-title" text="Team 6 - UET" />
                                <Label styleClass="footer-text" text="Dự án đấu giá trực tuyến&#10;Môn học: Lập trình nâng cao&#10;VNU University of Engineering and Technology" wrapText="true" />
                            </VBox>

                            <VBox prefWidth="220" spacing="10">
                                <Label styleClass="footer-title" text="Về chúng tôi" />
                                <Label styleClass="footer-text" text="Giới thiệu&#10;Quy chế hoạt động&#10;Hướng dẫn sử dụng" wrapText="true" />
                            </VBox>

                            <VBox prefWidth="220" spacing="10">
                                <Label styleClass="footer-title" text="Chính sách" />
                                <Label styleClass="footer-text" text="Bảo mật&#10;Điều khoản sử dụng&#10;Quy định đấu giá" wrapText="true" />
                            </VBox>

                            <VBox prefWidth="260" spacing="10">
                                <Label styleClass="footer-title" text="Liên hệ nhanh" />
                                <Label styleClass="footer-text" text="📍  Cầu Giấy - Hà Nội&#10;📞  0398106007&#10;✉️  team6ltnc@gmail.com&#10;🕐  Trong giờ hành chính" wrapText="true" />
                            </VBox>
                        </HBox>

                        <Separator styleClass="footer-separator" />
                        <Label styleClass="copyright" text="Copyright 2026 © Team 6 - UET. All rights reserved." />
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
