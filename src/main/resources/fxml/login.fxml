<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<!--
    GIAO DIỆN ĐĂNG NHẬP (LOGIN SCREEN)
    Sử dụng BorderPane làm bố cục gốc.
    - Controller xử lý logic là HomeController.
    - File CSS áp dụng là style.css.
-->

<BorderPane prefHeight="860" prefWidth="1380" styleClass="root" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.HomeController">

    <!-- PHẦN TRÊN (TOP BAR): THANH ĐIỀU HƯỚNG -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="topbar">
            <!-- Khoảng cách lề cho thanh điều hướng -->
            <padding><Insets bottom="12" left="36" right="36" top="12" /></padding>
            
            <!-- Logo và Tên ứng dụng -->
                            <HBox alignment="CENTER_LEFT" spacing="10">
                    <ImageView fitHeight="42" preserveRatio="true">
                        <image>
                            <Image url="@../images/logouet1.png" />
                        </image>
                    </ImageView>
                    <VBox spacing="0">
                        <Label style="-fx-font-size: 20px;" styleClass="logo-main" text="UET" />
                        <Label style="-fx-font-size: 9px;" styleClass="logo-sub" text="AUCTION PLATFORM" />
                    </VBox>
                </HBox>
            
            <!-- Vùng đệm để đẩy các nút điều hướng sang phải -->
            <Region HBox.hgrow="ALWAYS" />
            
            <!-- Các nút liên kết trang -->
            <Button onAction="#goToHome" styleClass="nav-btn" text="Trang chủ" />
            <Button onAction="#goToAuctionList" styleClass="nav-btn" text="Tài sản đấu giá" />
            <Button onAction="#goToNews" styleClass="nav-btn" text="Tin tức" />
            <Button onAction="#goToContact" styleClass="nav-btn" text="Liên hệ" />
            
            <!-- Nút đăng nhập/đăng xuất động (quản lý bởi Controller) -->
            <Button fx:id="themeToggleBtn" onAction="#toggleTheme" styleClass="theme-toggle-btn" text="🌙" />
            <Button fx:id="loginButton" onAction="#goToLogin" styleClass="login-btn" text="Đăng nhập" />
        </HBox>
    </top>

    <!-- PHẦN GIỮA (CENTER): KHU VỰC NỘI DUNG CHÍNH (FORM ĐĂNG NHẬP) -->
    <center>
        <HBox alignment="CENTER" spacing="0">
            
            <!-- KHỐI BÊN TRÁI: THÔNG TIN GIỚI THIỆU & QUẢNG BÁ -->
            <VBox prefWidth="700" spacing="28" styleClass="auth-left">
                <!-- Padding cho khối giới thiệu -->
                <padding><Insets bottom="52" left="52" right="52" top="52" /></padding>

                <Label styleClass="auth-title" text="Đăng nhập hệ thống đấu giá" />
                <Label styleClass="auth-desc" text="Truy cập tài khoản để theo dõi phiên đấu giá, tài sản quan tâm, lịch sử tham gia và trạng thái hồ sơ." wrapText="true" />

                <!-- Banner đồ họa giới thiệu tính năng nổi bật -->
                <AnchorPane prefHeight="300" style="-fx-background-radius: 20;" styleClass="auth-visual">
                    <children>
                        <Label layoutX="36" layoutY="36" styleClass="banner-chip" text="🔐  AUREX SECURE ACCESS" />
                        <Label layoutX="36" layoutY="80" styleClass="banner-title" text="XÁC THỰC NHANH&#10;BẢO MẬT CAO&#10;THEO DÕI DỄ DÀNG" />
                        <Label layoutX="36" layoutY="200" styleClass="banner-desc" text="Hệ thống đăng nhập bảo mật nhiều lớp cho nền tảng đấu giá chuyên nghiệp." wrapText="true" />
                    </children>
                </AnchorPane>

                <!-- Ba thẻ thông tin nhỏ (Thống kê / Điểm nhấn) -->
                <HBox spacing="16">
                    <VBox prefWidth="180" styleClass="mini-info-card">
                        <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>
                        <Label styleClass="mini-info-number" text="24/7" />
                        <Label styleClass="mini-info-text" text="Truy cập mọi lúc" />
                    </VBox>
                    <VBox prefWidth="180" styleClass="mini-info-card">
                        <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>
                        <Label styleClass="mini-info-number" text="2FA" />
                        <Label styleClass="mini-info-text" text="Tăng cường bảo mật" />
                    </VBox>
                    <VBox prefWidth="180" styleClass="mini-info-card">
                        <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>
                        <Label styleClass="mini-info-number" text="1 chạm" />
                        <Label styleClass="mini-info-text" text="Theo dõi phiên nhanh" />
                    </VBox>
                </HBox>
            </VBox>

            <!-- KHỐI BÊN PHẢI: FORM ĐĂNG NHẬP (USER LOGIN FORM) -->
            <VBox prefWidth="520" spacing="22" styleClass="auth-panel">
                <padding><Insets bottom="52" left="48" right="48" top="52" /></padding>

                <!-- Tiêu đề Form -->
                <Label styleClass="login-panel-title" text="🔑  Đăng nhập" />
                <Label styleClass="login-panel-text" text="Nhập thông tin để tiếp tục sử dụng hệ thống." />

                <!-- Nhóm: Ô nhập Tên đăng nhập / Email -->
                <VBox spacing="8">
                    <Label styleClass="field-label" text="Tên đăng nhập / Email" />
                    <TextField fx:id="usernameField" promptText="Nhập tên đăng nhập hoặc email" styleClass="mail-field" />
                </VBox>

                <!-- Nhóm: Ô nhập Mật khẩu (Có nút ẩn/hiện) -->
                <VBox spacing="8">
                    <Label styleClass="field-label" text="Mật khẩu" />
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <!-- Trường mật khẩu ẩn (mặc định) -->
                        <PasswordField fx:id="passwordField" promptText="Nhập mật khẩu" styleClass="mail-field" HBox.hgrow="ALWAYS" />
                        <!-- Trường văn bản để hiển thị mật khẩu khi nhấn nút (được quản lý trạng thái ẩn/hiện bởi Controller) -->
                        <TextField fx:id="visiblePasswordField" managed="false" promptText="Nhập mật khẩu" styleClass="mail-field" visible="false" HBox.hgrow="ALWAYS" />
                        <!-- Nút ấn để Toggle hiển thị mật khẩu -->
                        <Button fx:id="togglePasswordButton" styleClass="password-eye-btn" text="👁" />
                    </HBox>
                </VBox>

                <!-- Lựa chọn ghi nhớ đăng nhập và Quên mật khẩu -->
                <HBox alignment="CENTER_LEFT">
                    <CheckBox styleClass="check-auth" text="Ghi nhớ đăng nhập" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Hyperlink onAction="#goToForgotPassword" styleClass="auth-link" text="Quên mật khẩu?" />
                </HBox>

                <!-- Nút thao tác chính: Đăng nhập -->
                <Button maxWidth="1.7976931348623157E308" onAction="#handleLogin" styleClass="primary-btn" text="Đăng nhập hệ thống" />
                <!-- Tùy chọn đăng nhập bằng phương thức khác -->
                <Button maxWidth="1.7976931348623157E308" styleClass="secondary-btn" text="Đăng nhập bằng số điện thoại" />

                <!-- Liên kết chuyển sang màn hình Đăng ký -->
                <HBox alignment="CENTER" spacing="4">
                    <Label styleClass="muted-text" text="Chưa có tài khoản?" />
                    <Hyperlink onAction="#goToRegister" styleClass="auth-link" text="Đăng ký ngay" />
                </HBox>

                <!-- Đường kẻ phân cách -->
                <Separator />

                <!-- Hộp thông báo/lưu ý dành cho người dùng -->
                <VBox spacing="10" styleClass="auth-note-box">
                    <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>
                    <Label styleClass="note-title" text="📌  Lưu ý" />
                    <Label styleClass="login-panel-note" text="✓  Tài khoản đã xác thực có thể tham gia đấu giá ngay&#10;✓  Hồ sơ chưa hoàn tất sẽ bị giới hạn một số chức năng&#10;✓  Hỗ trợ đăng nhập qua CCCD điện tử&#10;✓  An toàn &amp; bảo mật&#10;" wrapText="true" />
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
