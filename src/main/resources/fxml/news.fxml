                                        <image>
                                            <Image url="@../images/news_featured.jpg" />
                                        </image>
                                    </ImageView>
                                </StackPane>
                                <VBox alignment="CENTER_LEFT" spacing="12" HBox.hgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="8">
                                        <Label styleClass="badge-vip" text="TIÊU ĐIỂM" />
                                        <Label style="-fx-text-fill: #8a8a8a;" text="•" />
                                        <Label styleClass="muted-text" text="07/04/2026" />
                                    </HBox>
                                    <Label style="-fx-font-size: 22px; -fx-font-weight: 900; -fx-text-fill: #1a1a1a;" text="Nâng cấp hệ thống bảo mật &amp; Quy trình xác thực đấu giá trực tuyến năm 2026" wrapText="true" />
                                    <Label style="-fx-line-spacing: 4px;" styleClass="news-text" text="Nhằm mang lại trải nghiệm tối ưu và đảm bảo tính minh bạch pháp lý tuyệt đối cho các thành viên, Team 6 - UET nâng cấp hệ thống ký quỹ tự động và tích hợp xác thực đa nhân tố. Bản cập nhật sẽ giúp tăng 100% tốc độ thực thi giao dịch..." wrapText="true" />
                                    <Region VBox.vgrow="ALWAYS" />
                                    <Button onAction="#handleComingSoon" style="-fx-padding: 10 20;" styleClass="primary-btn" text="Đọc bài viết tiêu điểm  →" />
                                </VBox>
                            </HBox>

                            <!-- Regular News Grid Row 1 -->
                            <HBox spacing="20">
