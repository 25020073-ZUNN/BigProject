                                <padding>
                                    <Insets bottom="20" left="20" right="20" top="20" />
                                </padding>
                                <Label styleClass="section-title-dark" text="TÌM KIẾM TIN TỨC" />
                                <Separator />
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <TextField promptText="Nhập từ khóa tìm kiếm..." styleClass="search-bar-field" HBox.hgrow="ALWAYS" />
                                    <Button onAction="#handleComingSoon" style="-fx-padding: 10 14; -fx-min-width: 44;" styleClass="primary-btn" text="🔍" />
                                </HBox>
                            </VBox>

                            <!-- Categories -->
                            <VBox spacing="15" styleClass="detail-side-card">
                                <padding>
                                    <Insets bottom="20" left="20" right="20" top="20" />
                                </padding>
                                <Label styleClass="section-title-dark" text="DANH MỤC TIN TỨC" />
                                <Separator />
                                <VBox spacing="10">
                                    <Button onAction="#handleComingSoon" styleClass="news-category-btn" text="• Thông báo mới (12)" />
                                    <Button onAction="#handleComingSoon" styleClass="news-category-btn" text="• Thị trường đấu giá (08)" />
                                    <Button onAction="#handleComingSoon" styleClass="news-category-btn" text="• Hướng dẫn sử dụng (15)" />
