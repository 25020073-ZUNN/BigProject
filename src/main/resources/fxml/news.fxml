                    <!-- HERO SECTION FOR NEWS -->
                    <VBox spacing="12" styleClass="page-hero-small">
                        <padding>
                            <Insets bottom="44" left="48" right="48" top="44" />
                        </padding>
                        <Label styleClass="hero-small" text="TIN TỨC &amp; THÔNG BÁO" />
                        <Label styleClass="hero-title" text="Cập nhật những thông tin mới nhất từ Team 6 - UET" />
                        <Label styleClass="hero-desc" text="Thông tin về dự án đấu giá trực tuyến, nghiên cứu công nghệ mới và thông tin môn học." />
                    </VBox>

                    <!-- MAIN NEWS CONTENT -->
                    <HBox spacing="30">
                        <padding>
                            <Insets bottom="36" left="48" right="48" top="0" />
                        </padding>

                        <!-- NEWS LIST -->
                        <VBox spacing="25" HBox.hgrow="ALWAYS">
                            <!-- Featured News (Premium Row Layout) -->
                            <HBox spacing="24" styleClass="content-card">
                                <padding>
                                    <Insets bottom="24" left="24" right="24" top="24" />
                                </padding>
                                <StackPane maxWidth="380" minWidth="380" prefHeight="250" prefWidth="380" styleClass="news-thumb" HBox.hgrow="NEVER">
                                    <ImageView fitHeight="250" fitWidth="380" preserveRatio="false">
                                        <clip>
                                            <Rectangle arcHeight="24" arcWidth="24" height="250" width="380" />
