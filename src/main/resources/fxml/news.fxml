                            <!-- Popular News -->
                            <VBox spacing="15" styleClass="detail-side-card">
                                <padding>
                                    <Insets bottom="20" left="20" right="20" top="20" />
                                </padding>
                                <Label styleClass="section-title-dark" text="TIN XEM NHIỀU NHẤT" />
                                <Separator />
                                <VBox spacing="15">
                                    <VBox spacing="5">
                                        <Label style="-fx-font-size: 11px;" styleClass="muted-text" text="01/04/2026" />
                                        <Label styleClass="field-label" text="Top 10 tài sản có giá trị đấu giá cao nhất quý I" wrapText="true" />
                                    </VBox>
                                    <VBox spacing="5">
                                        <Label style="-fx-font-size: 11px;" styleClass="muted-text" text="28/03/2026" />
                                        <Label styleClass="field-label" text="Chính sách bảo mật thông tin người tham gia đấu giá" wrapText="true" />
                                    </VBox>
                                    <VBox spacing="5">
                                        <Label style="-fx-font-size: 11px;" styleClass="muted-text" text="25/03/2026" />
                                        <Label styleClass="field-label" text="Lịch nghỉ lễ và hoạt động của hệ thống Team 6 - UET" wrapText="true" />
                                    </VBox>
                                </VBox>
                            </VBox>

                            <!-- Subscription box -->
                            <VBox spacing="15" styleClass="side-info-card-dark">
                                <padding>
                                    <Insets bottom="25" left="25" right="25" top="25" />
                                </padding>
                                <Label styleClass="banner-title" text="ĐĂNG KÝ BẢN TIN" />
                                <Label styleClass="banner-desc" text="Nhận những tin tức mới nhất trực tiếp vào hộp thư của bạn." wrapText="true" />
                                <TextField promptText="Email của bạn" styleClass="mail-field" />
                                <Button maxWidth="1.7976931348623157E308" onAction="#handleSubscribe" styleClass="primary-btn" text="Gửi đăng ký" />
                            </VBox>
                        </VBox>
                    </HBox>

                    <!-- FOOTER REUSED -->
                    <!-- FOOTER -->
                    <VBox spacing="22" styleClass="footer">
