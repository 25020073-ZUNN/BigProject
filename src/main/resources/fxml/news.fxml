                                        <Button onAction="#handleComingSoon" style="-fx-padding: 0;" styleClass="auth-link" text="Xem chi tiết" />
                                    </VBox>
                                </VBox>

                                <!-- Card 2 -->
                                <VBox prefWidth="400" spacing="12" styleClass="news-card" HBox.hgrow="ALWAYS">
                                    <StackPane prefHeight="180" styleClass="news-thumb">
                                        <ImageView fitHeight="180" fitWidth="368" preserveRatio="false">
                                            <clip>
                                                <Rectangle arcHeight="20" arcWidth="20" height="180" width="368" />
                                            </clip>
                                            <image>
                                                <Image url="@../images/news_mobile.jpg" />
                                            </image>
                                        </ImageView>
                                    </StackPane>
                                    <VBox spacing="8" styleClass="news-info">
                                        <padding>
                                            <Insets bottom="16" left="16" right="16" top="16" />
                                        </padding>
                                        <HBox alignment="CENTER_LEFT" spacing="8">
                                            <Label styleClass="badge-new" text="CÔNG NGHỆ" />
                                            <Label style="-fx-font-size: 11px;" styleClass="muted-text" text="•  05/04/2026" />
                                        </HBox>
                                        <Label style="-fx-font-size: 15px;" styleClass="news-title" text="Ra mắt bản thử nghiệm giao diện di động tối ưu trải nghiệm người dùng" wrapText="true" />
                                        <Label styleClass="news-text" text="Bản cập nhật giao diện mới hỗ trợ xem luồng đấu giá thời gian thực trên các thiết bị di động, tối ưu hóa độ trễ kết nối socket chỉ còn dưới 50ms." wrapText="true" />
