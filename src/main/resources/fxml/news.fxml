                                        <Button onAction="#handleComingSoon" style="-fx-padding: 0;" styleClass="auth-link" text="Xem chi tiết" />
                                    </VBox>
                                </VBox>

                                <!-- Card 4 -->
                                <VBox prefWidth="400" spacing="12" styleClass="news-card" HBox.hgrow="ALWAYS">
                                <StackPane prefHeight="180" styleClass="news-thumb">
                                    <ImageView fitHeight="180" fitWidth="368" preserveRatio="false">
                                        <clip>
                                            <Rectangle arcHeight="20" arcWidth="20" height="180" width="368" />
                                        </clip>
                                        <image>
                                            <Image url="@../images/news_escrow.jpg" />
                                        </image>
                                    </ImageView>
                                </StackPane>
                                    <VBox spacing="8" styleClass="news-info">
                                        <padding>
                                            <Insets bottom="16" left="16" right="16" top="16" />
                                        </padding>
                                        <HBox alignment="CENTER_LEFT" spacing="8">
                                            <Label styleClass="badge-soft" text="HƯỚNG DẪN" />
                                            <Label style="-fx-font-size: 11px;" styleClass="muted-text" text="•  03/04/2026" />
                                        </HBox>
                                        <Label style="-fx-font-size: 15px;" styleClass="news-title" text="Cẩm nang tham gia ký quỹ và bảo lãnh tài sản an toàn cho người mới" wrapText="true" />
                                        <Label styleClass="news-text" text="Hướng dẫn từng bước thực hiện nạp tiền, đặt cọc và hoàn trả quỹ tự động nhanh chóng trong vòng 5 phút sau khi phiên kết thúc." wrapText="true" />
                                        <Region prefHeight="8" />
                                        <Button onAction="#handleComingSoon" style="-fx-padding: 0;" styleClass="auth-link" text="Xem chi tiết" />
                                    </VBox>
                                </VBox>
                            </HBox>
                        </VBox>

                        <VBox maxWidth="350" minWidth="350" prefWidth="350" spacing="25">
