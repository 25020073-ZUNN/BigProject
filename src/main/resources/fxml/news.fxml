                            </VBox>
                            <VBox prefWidth="260" spacing="10">
                                <Label styleClass="footer-title" text="Liên hệ nhanh" />
                                <Label styleClass="footer-text" text="📍  Cầu Giấy - Hà Nội&#10;📞  0398106007&#10;✉️  team6ltnc@gmail.com&#10;🕐  Trong giờ hành chính" wrapText="true" />
                            </VBox>
                        </HBox>
                        <Separator styleClass="footer-separator" />
                        <Label styleClass="copyright" text="Copyright 2026 © Team 6 - UET. All rights reserved." />
