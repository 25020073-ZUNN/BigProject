                                        </image>
                                    </ImageView>
                                </StackPane>
                                    <VBox spacing="8" styleClass="news-info">
                                        <padding>
                                            <Insets bottom="16" left="16" right="16" top="16" />
                                        </padding>
                                        <HBox alignment="CENTER_LEFT" spacing="8">
                                            <Label styleClass="badge-vip" text="THỊ TRƯỜNG" />
                                            <Label style="-fx-font-size: 11px;" styleClass="muted-text" text="•  04/04/2026" />
                                        </HBox>
                                        <Label style="-fx-font-size: 15px;" styleClass="news-title" text="Xu hướng ứng dụng công nghệ chuỗi khối trong đấu giá tài sản" wrapText="true" />
