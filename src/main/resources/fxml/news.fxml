                                        <HBox alignment="CENTER_LEFT" spacing="8">
                                            <Label styleClass="badge-live" text="THÔNG BÁO" />
                                            <Label style="-fx-font-size: 11px;" styleClass="muted-text" text="•  06/04/2026" />
                                        </HBox>
                                        <Label style="-fx-font-size: 15px;" styleClass="news-title" text="Mở rộng danh mục đấu giá tài sản số và thanh lý doanh nghiệp" wrapText="true" />
                                        <Label styleClass="news-text" text="Hệ thống chính thức bổ sung nhóm tài sản công nghệ, bản quyền số và thiết bị văn phòng từ quý II/2026, mở ra nhiều cơ hội tham gia thực tiễn cho học viên." wrapText="true" />
