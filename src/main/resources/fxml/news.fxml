                                        <Button onAction="#handleComingSoon" style="-fx-padding: 0;" styleClass="auth-link" text="Xem chi tiết" />
                                    </VBox>
                                </VBox>
                            </HBox>

                            <!-- Regular News Grid Row 2 -->
                            <HBox spacing="20">
                                <!-- Card 3 -->
                                <VBox prefWidth="400" spacing="12" styleClass="news-card" HBox.hgrow="ALWAYS">
