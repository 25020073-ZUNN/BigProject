<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.controller.SessionCatalogController"
            prefWidth="1380"
            prefHeight="920"
            stylesheets="@style.css"
            styleClass="root">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="18" styleClass="topbar">
                <padding>
                    <Insets top="14" right="28" bottom="14" left="28"/>
                </padding>

                <VBox spacing="0">
                    <Label text="AUREX" styleClass="logo-main"/>
                    <Label text="AUCTION PLATFORM" styleClass="logo-sub"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Trang chủ" onAction="#goToHome" styleClass="nav-btn"/>
                <Button text="Tài sản đấu giá" onAction="#goToAuctionList" styleClass="nav-btn"/>
                <Button text="Phiên đấu giá" onAction="#goToSessions" styleClass="nav-btn-active"/>
                <Button text="Tin tức" onAction="#goToNews" styleClass="nav-btn"/>
                <Button text="Liên hệ" onAction="#goToContact" styleClass="nav-btn"/>
                <Button fx:id="loginButton" text="Đăng nhập" onAction="#goToLogin" styleClass="login-btn"/>
            </HBox>

            <VBox spacing="12" styleClass="page-hero-small">
                <padding>
                    <Insets top="24" right="42" bottom="24" left="42"/>
                </padding>
                <Label text="Danh sách phiên đấu giá thật" styleClass="hero-title-small"/>
                <Label text="Theo dõi phiên sắp diễn ra, đang diễn ra và đã kết thúc bằng dữ liệu thật."
                       styleClass="hero-desc" wrapText="true"/>
            </VBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="main-scroll">
            <content>
                <VBox spacing="24" styleClass="page-section">
                    <padding>
                        <Insets top="24" right="42" bottom="32" left="42"/>
                    </padding>

                    <VBox spacing="16" styleClass="filter-box">
                        <padding>
                            <Insets top="18" right="18" bottom="18" left="18"/>
                        </padding>

                        <HBox spacing="14" alignment="CENTER_LEFT">
                            <TextField fx:id="searchField" promptText="Tìm theo tên phiên, mã phiên, mã tài sản, người bán..." HBox.hgrow="ALWAYS" styleClass="mail-field"/>
                            <ComboBox fx:id="statusFilter" promptText="Trạng thái" prefWidth="180" styleClass="mail-field"/>
                            <Button text="Tìm kiếm" onAction="#handleSearch" styleClass="primary-btn"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="14">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Phiên đang diễn ra" styleClass="section-title-dark"/>
                            <Label text="LIVE" styleClass="badge-live"/>
                        </HBox>
                        <VBox fx:id="runningSessionsContainer" spacing="14"/>
                    </VBox>

                    <VBox spacing="14">
                        <Label text="Phiên sắp diễn ra" styleClass="section-title-dark"/>
                        <VBox fx:id="upcomingSessionsContainer" spacing="14"/>
                    </VBox>

                    <VBox spacing="14">
                        <Label text="Phiên đã kết thúc" styleClass="section-title-dark"/>
                        <VBox fx:id="finishedSessionsContainer" spacing="14"/>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
