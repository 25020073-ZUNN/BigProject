<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
    GIAO DIỆN ĐĂNG NHẬP (LOGIN SCREEN)
    Sử dụng BorderPane làm bố cục gốc.
    - Controller xử lý logic là HomeController.
    - File CSS áp dụng là style.css.
-->
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.controller.HomeController"
            prefWidth="1380" prefHeight="860" stylesheets="@style.css" styleClass="root">

    <!-- PHẦN TRÊN (TOP BAR): THANH ĐIỀU HƯỚNG -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="topbar">
            <!-- Khoảng cách lề cho thanh điều hướng -->
            <padding><Insets top="12" right="36" bottom="12" left="36"/></padding>
            
            <!-- Logo và Tên ứng dụng -->
            <VBox spacing="0">
                <Label text="AUREX" styleClass="logo-main"/>
                <Label text="AUCTION PLATFORM" styleClass="logo-sub"/>
            </VBox>
            
            <!-- Vùng đệm để đẩy các nút điều hướng sang phải -->
            <Region HBox.hgrow="ALWAYS"/>
            
            <!-- Các nút liên kết trang -->
            <Button text="Trang chủ" onAction="#goToHome" styleClass="nav-btn"/>
            <Button text="Tài sản đấu giá" onAction="#goToAuctionList" styleClass="nav-btn"/>
            <Button text="Phiên đấu giá" onAction="#goToSessions" styleClass="nav-btn"/>
            <Button text="Tin tức" onAction="#goToNews" styleClass="nav-btn"/>
            <Button text="Liên hệ" onAction="#goToContact" styleClass="nav-btn"/>
            
            <!-- Nút đăng nhập/đăng xuất động (quản lý bởi Controller) -->
            <Button fx:id="loginButton" text="Đăng nhập" onAction="#goToLogin" styleClass="login-btn"/>
        </HBox>
    </top>

    <!-- PHẦN GIỮA (CENTER): KHU VỰC NỘI DUNG CHÍNH (FORM ĐĂNG NHẬP) -->
    <center>
        <HBox spacing="0" alignment="CENTER">
            
            <!-- KHỐI BÊN TRÁI: THÔNG TIN GIỚI THIỆU & QUẢNG BÁ -->
            <VBox prefWidth="700" spacing="28" styleClass="auth-left">
                <!-- Padding cho khối giới thiệu -->
                <padding><Insets top="52" right="52" bottom="52" left="52"/></padding>

                <Label text="Đăng nhập hệ thống đấu giá" styleClass="auth-title"/>
                <Label text="Truy cập tài khoản để theo dõi phiên đấu giá, tài sản quan tâm, lịch sử tham gia và trạng thái hồ sơ."
                       wrapText="true" styleClass="auth-desc"/>

                <!-- Banner đồ họa giới thiệu tính năng nổi bật -->
                <AnchorPane prefHeight="300" styleClass="auth-visual"
                            style="-fx-background-radius: 20;">
                    <children>
                        <Label layoutX="36" layoutY="36" text="🔐  AUREX SECURE ACCESS" styleClass="banner-chip"/>
                        <Label layoutX="36" layoutY="80"
                               text="XÁC THỰC NHANH&#10;BẢO MẬT CAO&#10;THEO DÕI DỄ DÀNG"
                               styleClass="banner-title"/>
                        <Label layoutX="36" layoutY="200"
                               text="Hệ thống đăng nhập bảo mật nhiều lớp cho nền tảng đấu giá chuyên nghiệp."
                               styleClass="banner-desc" wrapText="true"/>
                    </children>
                </AnchorPane>

                <!-- Ba thẻ thông tin nhỏ (Thống kê / Điểm nhấn) -->
                <HBox spacing="16">
                    <VBox prefWidth="180" styleClass="mini-info-card">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <Label text="24/7" styleClass="mini-info-number"/>
                        <Label text="Truy cập mọi lúc" styleClass="mini-info-text"/>
                    </VBox>
                    <VBox prefWidth="180" styleClass="mini-info-card">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <Label text="2FA" styleClass="mini-info-number"/>
                        <Label text="Tăng cường bảo mật" styleClass="mini-info-text"/>
                    </VBox>
                    <VBox prefWidth="180" styleClass="mini-info-card">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <Label text="1 chạm" styleClass="mini-info-number"/>
                        <Label text="Theo dõi phiên nhanh" styleClass="mini-info-text"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- KHỐI BÊN PHẢI: FORM ĐĂNG NHẬP (USER LOGIN FORM) -->
            <VBox prefWidth="520" spacing="22" styleClass="auth-panel">
                <padding><Insets top="52" right="48" bottom="52" left="48"/></padding>

                <!-- Tiêu đề Form -->
                <Label text="🔑  Đăng nhập" styleClass="login-panel-title"/>
                <Label text="Nhập thông tin để tiếp tục sử dụng hệ thống." styleClass="login-panel-text"/>

                <!-- Nhóm: Ô nhập Tên đăng nhập / Email -->
                <VBox spacing="8">
                    <Label text="Tên đăng nhập / Email" styleClass="field-label"/>
                    <TextField fx:id="usernameField" promptText="Nhập tên đăng nhập hoặc email" styleClass="mail-field"/>
                </VBox>

                <!-- Nhóm: Ô nhập Mật khẩu (Có nút ẩn/hiện) -->
                <VBox spacing="8">
                    <Label text="Mật khẩu" styleClass="field-label"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <!-- Trường mật khẩu ẩn (mặc định) -->
                        <PasswordField fx:id="passwordField" promptText="Nhập mật khẩu" styleClass="mail-field" HBox.hgrow="ALWAYS"/>
                        <!-- Trường văn bản để hiển thị mật khẩu khi nhấn nút (được quản lý trạng thái ẩn/hiện bởi Controller) -->
                        <TextField fx:id="visiblePasswordField" promptText="Nhập mật khẩu" styleClass="mail-field" visible="false" managed="false" HBox.hgrow="ALWAYS"/>
                        <!-- Nút ấn để Toggle hiển thị mật khẩu -->
                        <Button fx:id="togglePasswordButton" text="👁" styleClass="password-eye-btn"/>
                    </HBox>
                </VBox>

                <!-- Lựa chọn ghi nhớ đăng nhập và Quên mật khẩu -->
                <HBox alignment="CENTER_LEFT">
                    <CheckBox text="Ghi nhớ đăng nhập" styleClass="check-auth"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Hyperlink text="Quên mật khẩu?" styleClass="auth-link"/>
                </HBox>

                <!-- Nút thao tác chính: Đăng nhập -->
                <Button text="Đăng nhập hệ thống" maxWidth="1.7976931348623157E308"
                        onAction="#handleLogin" styleClass="primary-btn"/>
                <!-- Tùy chọn đăng nhập bằng phương thức khác -->
                <Button text="Đăng nhập bằng CCCD / Định danh" maxWidth="1.7976931348623157E308"
                        styleClass="secondary-btn"/>

                <!-- Liên kết chuyển sang màn hình Đăng ký -->
                <HBox alignment="CENTER" spacing="4">
                    <Label text="Chưa có tài khoản?" styleClass="muted-text"/>
                    <Hyperlink text="Đăng ký ngay" onAction="#goToRegister" styleClass="auth-link"/>
                </HBox>

                <!-- Đường kẻ phân cách -->
                <Separator/>

                <!-- Hộp thông báo/lưu ý dành cho người dùng -->
                <VBox spacing="10" styleClass="auth-note-box">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="📌  Lưu ý" styleClass="note-title"/>
                    <Label text="✓  Tài khoản đã xác thực có thể tham gia đấu giá ngay&#10;✓  Hồ sơ chưa hoàn tất sẽ bị giới hạn một số chức năng&#10;✓  Hỗ trợ đăng nhập qua CCCD điện tử"
                           wrapText="true" styleClass="login-panel-note"/>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>