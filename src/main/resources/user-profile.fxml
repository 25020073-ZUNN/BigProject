<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.controller.UserProfileController"
            prefWidth="1380" prefHeight="920" stylesheets="@style.css" styleClass="root">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="topbar">
                <padding><Insets top="12" right="36" bottom="12" left="36"/></padding>
                <VBox spacing="0">
                    <Label text="AUREX" styleClass="logo-main"/>
                    <Label text="AUCTION PLATFORM" styleClass="logo-sub"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Trang chủ" onAction="#goToHome" styleClass="nav-btn"/>
                <Button text="Tài sản đấu giá" onAction="#goToAuctionList" styleClass="nav-btn"/>
                <Button text="Phiên đấu giá" onAction="#goToSessions" styleClass="nav-btn"/>
                <Button text="Tin tức" onAction="#goToNews" styleClass="nav-btn"/>
                <Button text="Liên hệ" onAction="#goToContact" styleClass="nav-btn"/>
                <Button fx:id="loginButton" text="Đăng xuất" onAction="#handleLogout" styleClass="login-btn"/>
            </HBox>

            <!-- Page Hero -->
            <VBox spacing="6" styleClass="page-hero-small" alignment="CENTER">
                <padding><Insets top="28" right="56" bottom="28" left="56"/></padding>
                <Label text="QUẢN LÝ HỒ SƠ" styleClass="hero-small"/>
                <Label text="Thông tin tài khoản của bạn" styleClass="hero-title-small"/>
                <Label text="Cập nhật thông tin cá nhân hoặc xóa tài khoản khỏi hệ thống."
                       wrapText="true" styleClass="muted-text"/>
            </VBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="main-scroll">
            <content>
                <VBox spacing="0" alignment="TOP_CENTER">
                    <padding><Insets top="36" right="56" bottom="56" left="56"/></padding>

                    <HBox spacing="28" alignment="TOP_CENTER">

                        <!-- ═══ Cột trái: Thông tin tổng quan ═══ -->
                        <VBox prefWidth="340" spacing="0" styleClass="content-card">

                            <!-- Header gradient -->
                            <VBox alignment="CENTER" spacing="0"
                                  style="-fx-background-color: linear-gradient(to bottom right, #0078d4, #005a9e); -fx-background-radius: 16 16 0 0;">
                                <padding><Insets top="32" right="28" bottom="32" left="28"/></padding>

                                <!-- Avatar -->
                                <VBox alignment="CENTER" prefWidth="90" prefHeight="90"
                                      style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 50;">
                                    <Label text="👤" style="-fx-font-size: 42;"/>
                                </VBox>

                                <Region prefHeight="12"/>

                                <Label fx:id="lblUsername" text="Username"
                                       style="-fx-text-fill: #ffffff; -fx-font-size: 22px; -fx-font-weight: 900;"/>
                                <Region prefHeight="6"/>
                                <Label fx:id="lblRole" text="Vai trò: USER" styleClass="badge-live"/>
                            </VBox>

                            <!-- Info body -->
                            <VBox spacing="20">
                                <padding><Insets top="24" right="28" bottom="28" left="28"/></padding>

                                <VBox spacing="6">
                                    <Label text="💰  Số dư hiện tại" styleClass="field-label"/>
                                    <Label fx:id="lblBalance" text="0 VNĐ"
                                           style="-fx-text-fill: #107c10; -fx-font-size: 24px; -fx-font-weight: 900;"/>
                                </VBox>

                                <Separator/>

                                <VBox spacing="6">
                                    <Label text="📅  Tham gia từ" styleClass="field-label"/>
                                    <Label text="Dữ liệu đang cập nhật..." styleClass="muted-text"/>
                                </VBox>

                                <VBox spacing="6">
                                    <Label text="📊  Phiên đã tham gia" styleClass="field-label"/>
                                    <Label text="Đang tải..." styleClass="muted-text"/>
                                </VBox>
                            </VBox>
                        </VBox>

                        <!-- ═══ Cột phải: Form cập nhật ═══ -->
                        <VBox prefWidth="600" spacing="0" styleClass="content-card" HBox.hgrow="ALWAYS">

                            <!-- Form header -->
                            <VBox spacing="4" style="-fx-background-color: #fafafa; -fx-background-radius: 16 16 0 0; -fx-border-color: transparent transparent #e0e0e0 transparent; -fx-border-width: 0 0 1 0;">
                                <padding><Insets top="24" right="36" bottom="20" left="36"/></padding>
                                <Label text="✏️  Cập nhật thông tin" styleClass="partner-title"/>
                                <Label text="Chỉnh sửa thông tin cá nhân của bạn tại đây." styleClass="muted-text"/>
                            </VBox>

                            <!-- Form body -->
                            <VBox spacing="20">
                                <padding><Insets top="24" right="36" bottom="32" left="36"/></padding>

                                <VBox spacing="8">
                                    <Label text="Tên đăng nhập" styleClass="field-label"/>
                                    <Label text="Không thể thay đổi" styleClass="muted-text" style="-fx-font-size: 11px;"/>
                                    <TextField fx:id="txtUsername" disable="true" styleClass="mail-field"
                                               style="-fx-opacity: 0.6;"/>
                                </VBox>

                                <VBox spacing="8">
                                    <Label text="Họ và tên" styleClass="field-label"/>
                                    <TextField fx:id="txtFullName" promptText="Nhập họ và tên" styleClass="mail-field"/>
                                </VBox>

                                <VBox spacing="8">
                                    <Label text="Email liên hệ" styleClass="field-label"/>
                                    <TextField fx:id="txtEmail" promptText="Nhập email" styleClass="mail-field"/>
                                </VBox>

                                <Label fx:id="lblNotification" text="" styleClass="login-panel-note"
                                       style="-fx-text-fill: #ca5010;"/>

                                <HBox alignment="CENTER_RIGHT">
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="💾  Lưu thay đổi" onAction="#handleUpdateProfile" styleClass="primary-btn"/>
                                </HBox>
                            </VBox>

                            <Separator/>

                            <!-- Danger zone -->
                            <VBox spacing="12">
                                <padding><Insets top="20" right="36" bottom="28" left="36"/></padding>
                                <Label text="⚠️  Vùng nguy hiểm" styleClass="partner-title"
                                       style="-fx-text-fill: #d13438;"/>
                                <Label text="Hành động này sẽ vô hiệu hóa tài khoản của bạn vĩnh viễn. Bạn không thể khôi phục lại dữ liệu sau khi xóa."
                                       wrapText="true" styleClass="muted-text"/>
                                <Button text="🗑  Xóa tài khoản" onAction="#handleDeleteAccount"
                                        style="-fx-background-color: #ffffff; -fx-border-color: #d13438; -fx-text-fill: #d13438; -fx-border-width: 1.5; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 10 20; -fx-cursor: hand; -fx-font-weight: 700;"/>
                            </VBox>
                        </VBox>

                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
